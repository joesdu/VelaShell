<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dockc="using:VelaShell.Docking.Controls"
        xmlns:shapes="using:Avalonia.Controls.Shapes">

    <!-- 终端工作区(自研 VelaDock)底色 + 全局通用样式。标签本身的视觉
         (36px 条 / 32px 标签 / 状态点 / accent 顶线 / 关闭钮)内联在
         Docking/Controls/DockTabItem.axaml,与设计 nunbT 逐像素一致。 -->

    <Style Selector="dockc|DockWorkspaceControl">
        <Setter Property="Background" Value="{DynamicResource VelaBgPage}" />
    </Style>

    <!-- Single-line inputs center their text vertically (设计稿所有输入框文本均为垂直居中);
         the Fluent default leaves the presenter top-aligned, which reads as the text floating
         high whenever the box is taller than one line (worst in the settings panel's 30px
         NumericUpDown fields). Multi-line boxes keep top alignment. -->
    <Style Selector="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox[AcceptsReturn=True]">
        <Setter Property="VerticalContentAlignment" Value="Top" />
    </Style>
    <Style Selector="NumericUpDown">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Token-styled tooltips (small-flyout spec: bg-surface + border-secondary + corner 6). -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{DynamicResource VelaBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Context menus (design 会话右键菜单 style): one look for every right-click menu — the
         session tree, the SFTP list, and the dock tab strip. Same small-flyout tokens as the
         tooltip (bg-surface + border-secondary + corner 6), JB Mono 11, compact rows. -->
    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource VelaBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Hover/selected highlight uses the shared bg-hover token instead of the Fluent accent fill. -->
    <Style Selector="ContextMenu MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="ContextMenu MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="ContextMenu MenuItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
    </Style>

    <!-- Disabled items read as muted, not hidden. -->
    <Style Selector="ContextMenu MenuItem:disabled">
        <Setter Property="Foreground" Value="{DynamicResource VelaTextMuted}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <!-- 勾选项的勾号:与箭头同病同治 —— Fluent 也按 14 号字把它定死在 16x13,配 11 号字
         (文字实高 12)偏大。0.65 → 渲染约 10.4x8.5。比例是照着观感定的,不是算出来的:
         勾号是宽扁字形,与箭头等高反而显得重,所以两者同取 0.65 而非各自凑齐高度。
         缩放挂在 ToggleIconPresenter 上:勾号本身是模板里的匿名 Path,选择器点不到它;
         而 presenter 的 Width/Height 又是模板局部值、改不动,只有 RenderTransform 可用。
         布局槽仍是 16x16,勾号原位缩小,文字不位移。图标列(PART_IconPresenter)不受影响。 -->
    <Style Selector="ContextMenu MenuItem /template/ ContentControl#PART_ToggleIconPresenter">
        <Setter Property="RenderTransform" Value="scale(0.65)" />
    </Style>

    <!-- 子菜单箭头:Fluent 按它默认的 14 号字把 8x16 写死在模板里,菜单压到 11 号后箭头
         不跟着缩,16px 高的箭头配 11px 的字明显大一号。0.65 → 渲染约 10.4px,略低于字高。

         两个坑(改之前先读 MenuGlyphStyleTests):
         · 只能缩放,不能设 Width/Height/Fill —— 那三个是模板里写死的局部值,样式覆盖不了,
           设了不报错也不生效。布局槽仍是 8x16,箭头在原位缩小,不挤动行内其它元素。
         · 类型必须写 shapes|Path:默认 xmlns 下裸写的 Path 匹配不到这个部件,同样静默失效。 -->
    <Style Selector="ContextMenu MenuItem /template/ shapes|Path#PART_ChevronPath">
        <Setter Property="RenderTransform" Value="scale(0.65)" />
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Background" Value="{DynamicResource VelaBorderPrimary}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,4" />
    </Style>

    <!-- Tab-strip overflow controls (design nunbT pZGS4): 24px, corner 3, hover bg-hover. -->
    <Style Selector=":is(Button).tab-nav">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector=":is(Button).tab-nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector=":is(Button).tab-nav:disabled">
        <Setter Property="Opacity" Value="0.35" />
    </Style>

    <!-- Tab-list dropdown (and any MenuFlyout): same small-flyout look as the context menus. -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource VelaBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
    </Style>
    <!-- 下拉里当前激活的标签:accent + 加粗(DockGroupControl 挂 active-tab 类)。 -->
    <Style Selector="MenuFlyoutPresenter MenuItem.active-tab">
        <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <!-- 勾号与子菜单箭头:同 ContextMenu,见那边的说明。 -->
    <Style Selector="MenuFlyoutPresenter MenuItem /template/ ContentControl#PART_ToggleIconPresenter">
        <Setter Property="RenderTransform" Value="scale(0.65)" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem /template/ shapes|Path#PART_ChevronPath">
        <Setter Property="RenderTransform" Value="scale(0.65)" />
    </Style>

</Styles>
