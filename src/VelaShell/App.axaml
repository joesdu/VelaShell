<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             x:Class="VelaShell.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <!-- AvaloniaEdit 的控件模板随其主题提供;缺了它 TextEditor 无模板、内容不渲染。 -->
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://VelaShell/Themes/DockStyles.axaml" />
        <!-- antd 风格的前缀/后缀输入框容器(Border.input-affix),供各视图复用 -->
        <StyleInclude Source="avares://VelaShell/Themes/InputStyles.axaml" />
        <!-- 设置 → 外观 → 界面字体/字号:所有窗口(含设置窗口/各弹窗)统一继承;
             显式指定了 FontFamily/FontSize 的元素(终端、JB Mono 等宽文本、设计定字号)
             不受影响。运行时改动经 app.Resources 覆盖这两个令牌即时生效。 -->
        <Style Selector=":is(Window)">
            <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
            <Setter Property="FontSize" Value="{DynamicResource VelaUiFontSize}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/Generic.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/VelaTokens.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/VelaShellTokens.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- 界面字号默认值(设计 font-ui 13);运行时被 ApplyWindowAppearance 覆盖。 -->
            <sys:Double x:Key="VelaUiFontSize">13</sys:Double>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/DarkTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/LightTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
