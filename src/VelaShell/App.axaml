<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="using:System"
             xmlns:dockFluent="using:Dock.Avalonia.Themes.Fluent"
             xmlns:themes="using:VelaShell.Themes"
             x:Class="VelaShell.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <dockFluent:DockFluentTheme />
        <!-- AvaloniaEdit 的控件模板随其主题提供;缺了它 TextEditor 无模板、内容不渲染。 -->
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://VelaShell/Themes/DockStyles.axaml" />
        <!-- antd 风格的前缀/后缀输入框容器(Border.input-affix),供各视图复用 -->
        <StyleInclude Source="avares://VelaShell/Themes/InputStyles.axaml" />
        <!-- 设置 → 外观 → 界面字体/字号:所有窗口(含设置窗口/各弹窗)统一继承;
             显式指定了 FontFamily/FontSize 的元素(终端、JB Mono 等宽文本、设计定字号)
             不受影响。运行时改动经 app.Resources 覆盖这两个令牌即时生效。 -->
        <Style Selector=":is(Window)">
            <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
            <Setter Property="FontSize" Value="{DynamicResource VelaUiFontSize}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/Generic.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/VelaTokens.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/VelaShellTokens.axaml" />
                <ResourceInclude Source="avares://VelaShell.Controls/Themes/Icons.axaml" />
                <!-- Overrides Dock.Avalonia's document tab context menu (must come after the Dock
                     theme is applied; application resources win over theme resources). -->
                <ResourceInclude Source="avares://VelaShell/Themes/DockContextMenu.axaml" />
                <!-- Overrides Dock's tab-strip ScrollViewer theme: no inline edge arrows; fixed
                     scroll-left/right + tab-list dropdown at the strip's right end (design nunbT).
                     Instantiated directly (not ResourceInclude) so its Click handlers bind to the
                     x:Class code-behind. -->
                <themes:DockTabStripResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- 界面字号默认值(设计 font-ui 13);运行时被 ApplyWindowAppearance 覆盖。 -->
            <sys:Double x:Key="VelaUiFontSize">13</sys:Double>

            <!-- Dock document tab metrics per design frame nunbT: 32px tabs, padding [0,14],
                 JB Mono 11, dot/label/close gap 8. Brushes are themed in DockStyles.axaml. -->
            <sys:Double x:Key="DockFontSizeNormal">11</sys:Double>
            <sys:Double x:Key="DockDocumentTabItemMinHeight">32</sys:Double>
            <sys:Double x:Key="DockDocumentTabItemMinWidth">0</sys:Double>
            <Thickness x:Key="DockDocumentTabItemPadding">14,0</Thickness>
            <Thickness x:Key="DockTabContentMargin">0</Thickness>
            <sys:Double x:Key="DockTabContentSpacing">8</sys:Double>
            <sys:Double x:Key="DockDocumentTabHeaderContentSpacing">8</sys:Double>
            <sys:Double x:Key="DockDocumentTabItemSeparatorOpacity">0</sys:Double>

            <!-- Tab-strip separator (PART_DocumentSeperator): kept as a purely decorative 1px
                 line between the tabs and the per-tab toolbar below. Its focus-driven color
                 change (gray → accent-blue) is neutralized in DockStyles.axaml. -->
            <sys:Double x:Key="DockDocumentTabStripSeparatorSize">1</sys:Double>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/DarkTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/LightTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
