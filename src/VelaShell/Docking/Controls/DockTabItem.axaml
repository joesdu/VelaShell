<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:VelaShell.Docking.Controls"
             xmlns:docking="using:VelaShell.Docking"
             xmlns:conv="using:VelaShell.Converters"
             xmlns:pc="using:VelaShell.Controls.Controls"
             xmlns:views="using:VelaShell.Views"
             xmlns:services="using:VelaShell.Services"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:loc="using:VelaShell.Localization"
             x:Class="VelaShell.Docking.Controls.DockTabItem"
             x:DataType="docking:TerminalDocument"
             FontSize="11"
             VerticalAlignment="Stretch">

  <!-- 单个终端标签(设计 nunbT):32px 高、padding [0,14],状态点 7px + 连接标识色条
       3×12 + JB Mono 11 标题 + 11px 关闭钮,元素间距 8。激活 = tab-active 底 +
       2px accent 顶线;悬停 = bg-hover。视觉与原 Dock 重皮肤逐像素一致。 -->
  <UserControl.Styles>
    <Style Selector="local|DockTabItem">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextTertiary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.12" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="local|DockTabItem Border#TabRoot">
      <Setter Property="Background" Value="{DynamicResource VelaTabInactiveBg}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" Easing="CubicEaseOut" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="local|DockTabItem:pointerover:not(:selected)">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
    </Style>
    <Style Selector="local|DockTabItem:pointerover:not(:selected) Border#TabRoot">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="local|DockTabItem:selected">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="local|DockTabItem:selected Border#TabRoot">
      <Setter Property="Background" Value="{DynamicResource VelaTabActiveBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaAccent}" />
    </Style>
  </UserControl.Styles>

  <UserControl.ContextMenu>
    <!-- 与原 DockContextMenu.axaml 完全同构:关闭系列 + 拆分 + 标签位置;
         浮动与 MDI 按产品决策不存在。菜单外观走全局 ContextMenu 样式。 -->
    <ContextMenu>
      <!-- 同步输入频道:四个固定频道以颜色区分,加入后本标签的用户输入与频道内
           其他标签实时互通(对等转发见 SyncInputCoordinator)。 -->
      <MenuItem Header="{loc:Localize SyncInput_Menu}">
        <MenuItem.Icon>
          <pc:LucideIcon Width="13" Height="13" Data="{DynamicResource Icon.link-2}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </MenuItem.Icon>
        <MenuItem Header="{loc:Localize SyncInput_JoinChannelA}" Click="JoinChannelA_Click">
          <MenuItem.Icon>
            <Border Width="10" Height="10" CornerRadius="2"
                    Background="{x:Static services:SyncInputChannels.BrushA}" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Localize SyncInput_JoinChannelB}" Click="JoinChannelB_Click">
          <MenuItem.Icon>
            <Border Width="10" Height="10" CornerRadius="2"
                    Background="{x:Static services:SyncInputChannels.BrushB}" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Localize SyncInput_JoinChannelC}" Click="JoinChannelC_Click">
          <MenuItem.Icon>
            <Border Width="10" Height="10" CornerRadius="2"
                    Background="{x:Static services:SyncInputChannels.BrushC}" />
          </MenuItem.Icon>
        </MenuItem>
        <MenuItem Header="{loc:Localize SyncInput_JoinChannelD}" Click="JoinChannelD_Click">
          <MenuItem.Icon>
            <Border Width="10" Height="10" CornerRadius="2"
                    Background="{x:Static services:SyncInputChannels.BrushD}" />
          </MenuItem.Icon>
        </MenuItem>
        <Separator />
        <MenuItem Header="{loc:Localize SyncInput_LeaveAll}" Click="LeaveSyncChannel_Click" />
      </MenuItem>
      <Separator />
      <MenuItem Header="{loc:Localize Dock_Close}" Click="CloseTab_Click">
        <MenuItem.Icon>
          <pc:LucideIcon Width="13" Height="13" Data="{DynamicResource Icon.x}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="{loc:Localize Dock_CloseOthers}" Click="CloseOthers_Click" />
      <MenuItem Header="{loc:Localize Dock_CloseAll}" Click="CloseAll_Click" />
      <MenuItem Header="{loc:Localize Dock_CloseLeft}" Click="CloseLeft_Click" />
      <MenuItem Header="{loc:Localize Dock_CloseRight}" Click="CloseRight_Click" />
      <Separator />
      <MenuItem Header="{loc:Localize Dock_SplitHorizontal}" Click="SplitHorizontal_Click">
        <MenuItem.Icon>
          <pc:LucideIcon Width="13" Height="13" Data="{DynamicResource Icon.columns-2}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </MenuItem.Icon>
      </MenuItem>
      <MenuItem Header="{loc:Localize Dock_SplitVertical}" Click="SplitVertical_Click">
        <MenuItem.Icon>
          <pc:LucideIcon Width="13" Height="13" Data="{DynamicResource Icon.rows-2}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </MenuItem.Icon>
      </MenuItem>
      <Separator />
      <MenuItem Header="{loc:Localize Dock_TabsPosition}">
        <MenuItem.Icon>
          <pc:LucideIcon Width="13" Height="13" Data="{DynamicResource Icon.panel-top}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </MenuItem.Icon>
        <MenuItem Header="{loc:Localize Dock_TabsTop}" Click="TabsTop_Click" />
        <MenuItem Header="{loc:Localize Dock_TabsLeft}" Click="TabsLeft_Click" />
        <MenuItem Header="{loc:Localize Dock_TabsRight}" Click="TabsRight_Click" />
      </MenuItem>
    </ContextMenu>
  </UserControl.ContextMenu>

  <Border x:Name="TabRoot"
          MinHeight="32"
          Padding="14,0"
          BorderThickness="0,2,0,0"
          BorderBrush="Transparent"
          VerticalAlignment="Stretch">
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

      <!-- 同步输入频道字母:置于状态点之前,以频道标识色着色。 -->
      <TextBlock Text="{Binding Terminal.SyncChannelLetter}"
                 IsVisible="{Binding Terminal.IsInSyncChannel}"
                 Foreground="{Binding Terminal.SyncChannelBrush}"
                 FontWeight="Bold"
                 VerticalAlignment="Center">
        <TextBlock.RenderTransform>
          <TranslateTransform Y="-1" />
        </TextBlock.RenderTransform>
      </TextBlock>

      <!-- 状态点:上移 1px,补偿 mono 标题下伸部把视觉中心抬高。 -->
      <Ellipse Width="7" Height="7" VerticalAlignment="Center"
               Fill="{Binding Terminal.ConnectionStatus, Converter={x:Static conv:SessionStatusToBrushConverter.Instance}}">
        <Ellipse.RenderTransform>
          <TranslateTransform Y="-1" />
        </Ellipse.RenderTransform>
      </Ellipse>

      <StackPanel Orientation="Horizontal" Spacing="6">
        <!-- 连接标识色条:与 SFTP 面板头部同色联动(ConnectionAccent),本地终端为透明。 -->
        <Border Width="3" Height="12" CornerRadius="1.5"
                VerticalAlignment="Center"
                Background="{Binding Terminal.ConnectionAccentBrush}">
          <Border.RenderTransform>
            <TranslateTransform Y="-1" />
          </Border.RenderTransform>
        </Border>
        <!-- 标题:悬停 400ms 浮出该会话的资源面板(§4B.4/§11)。
             Tip 绑定 VM 而非直接内嵌视图:直接内嵌会在每个标签创建时就 eager 实例化
             整个 ResourceMonitorView(磁盘列表 + 进度条 + 十余条活绑定),N 个标签
             N 份常驻;改为 DataTemplate 后视图只在首次悬停弹出时才构造。 -->
        <TextBlock Text="{Binding Title}"
                   VerticalAlignment="Center"
                   ToolTip.ShowDelay="400"
                   ToolTip.Placement="Pointer"
                   ToolTip.Tip="{Binding Terminal.ResourceMonitor}">
          <TextBlock.DataTemplates>
            <DataTemplate DataType="vm:ResourceMonitorViewModel">
              <views:ResourceMonitorView />
            </DataTemplate>
          </TextBlock.DataTemplates>
        </TextBlock>
      </StackPanel>

      <!-- 关闭 x:11px lucide,与 11px 标题安静并排。 -->
      <Button Background="Transparent" Padding="0" Width="14" Height="14"
              BorderThickness="0"
              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
              Click="CloseTab_Click">
        <pc:LucideIcon Width="11" Height="11"
                       Data="{DynamicResource Icon.x}"
                       Foreground="{DynamicResource VelaTextTertiary}" />
      </Button>
    </StackPanel>
  </Border>
</UserControl>
