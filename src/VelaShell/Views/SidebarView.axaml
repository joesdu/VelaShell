<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.Presentation.ViewModels"
             xmlns:views="using:VelaShell.Views"
             xmlns:pc="using:VelaShell.Controls.Controls"
             xmlns:res="clr-namespace:VelaShell.Core.Resources;assembly=VelaShell.Core"
             xmlns:loc="using:VelaShell.Localization"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="876"
             x:Class="VelaShell.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

  <Grid x:Name="SidebarGrid" RowDefinitions="36,*,40"
        Background="{DynamicResource VelaBgSidebar}">

    <!-- 工具栏 -->
    <Border Grid.Row="0"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource VelaBorderPrimary}"
            Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{loc:Localize Sidebar_Explorer}"
                   Foreground="{DynamicResource VelaTextSecondary}"
                   FontFamily="{DynamicResource VelaTerminalFont}"
                   FontSize="11" FontWeight="Medium" LetterSpacing="1"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center">
          <Button Background="Transparent" Padding="0" Width="24" Height="24"
                  CornerRadius="3" Cursor="Hand"
                  Click="OpenConnectionProfile_Click"
                  ToolTip.Tip="{x:Static res:Strings.Sessions}">
            <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.plus}"
                           Foreground="{DynamicResource VelaTextTertiary}" />
          </Button>
          <Button Background="Transparent" Padding="0" Width="24" Height="24"
                  CornerRadius="3" Cursor="Hand">
            <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.ellipsis}"
                           Foreground="{DynamicResource VelaTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 嵌套网格:在可选的快捷命令区隐藏时,分隔条仍与相邻区域保持贴合。 -->
    <Grid x:Name="SidebarSectionsGrid" Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="80" />
        <RowDefinition Height="5" />
        <RowDefinition Height="180" MinHeight="100" />
      </Grid.RowDefinitions>

      <!-- 会话树 + 可选的快捷命令。 -->
      <Grid x:Name="SessionAndQuickGrid" Grid.Row="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" MinHeight="80" />
          <RowDefinition Height="0" />
          <RowDefinition Height="0" MinHeight="0" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <views:SessionTreeView DataContext="{Binding SessionTree}" Padding="0,8" />
        </ScrollViewer>

        <Border x:Name="QuickCommandsDivider" Grid.Row="1" Height="1"
                VerticalAlignment="Center"
                Background="{DynamicResource VelaBorderPrimary}"
                IsVisible="False" />
        <GridSplitter x:Name="QuickCommandsSplitter" Grid.Row="1"
                      Background="Transparent" ResizeDirection="Rows"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      IsVisible="False" />

        <Border x:Name="QuickCommandsSection" Grid.Row="2" IsVisible="False">
          <Grid RowDefinitions="36,*">
            <Border Grid.Row="0" BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource VelaBorderPrimary}" Padding="8,0">
              <Button x:Name="QuickCommandsToggle"
                      Background="Transparent" Padding="4,0" CornerRadius="3"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Click="ToggleQuickCommands_Click" Cursor="Hand"
                      ToolTip.Tip="{loc:Localize Sidebar_ToggleSection}">
                <Grid ColumnDefinitions="Auto,6,*">
                  <Panel Width="12" Height="12" VerticalAlignment="Center">
                    <pc:LucideIcon x:Name="QuickCommandsExpandedIcon" Width="12" Height="12"
                                   Data="{StaticResource Icon.chevron-down}"
                                   Foreground="{DynamicResource VelaTextTertiary}" />
                    <pc:LucideIcon x:Name="QuickCommandsCollapsedIcon" Width="12" Height="12"
                                   Data="{StaticResource Icon.chevron-right}"
                                   Foreground="{DynamicResource VelaTextTertiary}"
                                   IsVisible="False" />
                  </Panel>
                  <TextBlock Grid.Column="2" Text="{loc:Localize QuickCommands}"
                             Foreground="{DynamicResource VelaTextSecondary}"
                             FontFamily="{DynamicResource VelaTerminalFont}"
                             FontSize="11" FontWeight="Medium" LetterSpacing="1"
                             VerticalAlignment="Center" />
                </Grid>
              </Button>
            </Border>
            <views:QuickCommandsView x:Name="QuickCommandsContent" Grid.Row="1"
                                     DataContext="{Binding QuickCommands}" />
          </Grid>
        </Border>
      </Grid>

      <!-- 最近连接分隔条与整个上部区域保持相邻。 -->
      <Border x:Name="RecentConnectionsDivider" Grid.Row="1" Height="1"
              VerticalAlignment="Center"
              Background="{DynamicResource VelaBorderPrimary}" />
      <GridSplitter x:Name="RecentConnectionsSplitter" Grid.Row="1"
                    Background="Transparent" ResizeDirection="Rows"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

      <Border Grid.Row="2">
        <Grid RowDefinitions="36,*">
          <Border Grid.Row="0" BorderThickness="0,0,0,1"
                  BorderBrush="{DynamicResource VelaBorderPrimary}" Padding="8,0">
            <Grid ColumnDefinitions="Auto,6,*,Auto">
              <Button x:Name="RecentConnectionsToggle" Grid.Column="0" Grid.ColumnSpan="3"
                      Background="Transparent" Padding="4,0" CornerRadius="3"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Click="ToggleRecentConnections_Click" Cursor="Hand"
                      ToolTip.Tip="{loc:Localize Sidebar_ToggleSection}">
                <Grid ColumnDefinitions="Auto,6,*">
                  <Panel Width="12" Height="12" VerticalAlignment="Center">
                    <pc:LucideIcon x:Name="RecentConnectionsExpandedIcon" Width="12" Height="12"
                                   Data="{StaticResource Icon.chevron-down}"
                                   Foreground="{DynamicResource VelaTextTertiary}" />
                    <pc:LucideIcon x:Name="RecentConnectionsCollapsedIcon" Width="12" Height="12"
                                   Data="{StaticResource Icon.chevron-right}"
                                   Foreground="{DynamicResource VelaTextTertiary}"
                                   IsVisible="False" />
                  </Panel>
                  <TextBlock Grid.Column="2" Text="{loc:Localize RecentConnections}"
                             Foreground="{DynamicResource VelaTextSecondary}"
                             FontFamily="{DynamicResource VelaTerminalFont}"
                             FontSize="11" FontWeight="Medium" LetterSpacing="1"
                             VerticalAlignment="Center" />
                </Grid>
              </Button>
              <Button Grid.Column="3" Background="Transparent" Padding="0"
                      Width="24" Height="24" CornerRadius="3" Cursor="Hand"
                      Command="{Binding RecentConnections.RefreshCommand}"
                      ToolTip.Tip="{loc:Localize Sidebar_RefreshRecent}"
                      VerticalAlignment="Center">
                <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.history}"
                               Foreground="{DynamicResource VelaTextTertiary}" />
              </Button>
            </Grid>
          </Border>

          <ScrollViewer x:Name="RecentConnectionsContent" Grid.Row="1"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding RecentConnections.Connections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:RecentConnectionItemViewModel">
                  <Border Height="32" Padding="12,0" Cursor="Hand"
                          Background="Transparent" ToolTip.Tip="{Binding Tooltip}"
                          DoubleTapped="RecentConnection_DoubleTapped">
                    <Border.Styles>
                      <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
                      </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="Auto,*">
                      <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.timer}"
                                     Foreground="{DynamicResource VelaTextTertiary}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="{DynamicResource VelaTextSecondary}"
                                   FontFamily="{DynamicResource VelaTerminalFont}"
                                   FontSize="11" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding RelativeTime}"
                                   Foreground="{DynamicResource VelaTextMuted}"
                                   FontFamily="{DynamicResource VelaTerminalFont}"
                                   FontSize="9" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- 底部栏 -->
    <Border Grid.Row="2" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource VelaBorderPrimary}" Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="22" Height="22" CornerRadius="11"
                  Background="{DynamicResource VelaAccentDim}">
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.user}"
                           Foreground="{DynamicResource VelaAccent}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="root" Foreground="{DynamicResource VelaTextSecondary}"
                     FontFamily="{DynamicResource VelaTerminalFont}" FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Center">
          <Button Width="24" Height="24" Background="Transparent" Padding="0"
                  CornerRadius="3" Command="{Binding NotificationsCommand}"
                  ToolTip.Tip="{x:Static res:Strings.Notifications}" Cursor="Hand">
            <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.bell}"
                           Foreground="{DynamicResource VelaTextTertiary}" />
          </Button>
          <Button Width="24" Height="24" Background="Transparent" Padding="0"
                  CornerRadius="3" Click="OpenSettings_Click"
                  ToolTip.Tip="{x:Static res:Strings.Settings}" Cursor="Hand">
            <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.settings}"
                           Foreground="{DynamicResource VelaTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
