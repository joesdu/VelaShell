<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:pc="using:VelaShell.Controls.Controls"
             xmlns:loc="using:VelaShell.Localization"
             xmlns:res="clr-namespace:VelaShell.Core.Resources;assembly=VelaShell.Core"
             mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="36"
             x:Class="VelaShell.Views.TitleBarView"
             x:DataType="vm:MainWindowViewModel">

  <!-- 自绘标题栏(替代原生标题栏与文字菜单,菜单功能与命令面板重复故移除):
       左 = 产品 logo + 名称;右 = 全局功能图标组(GQQwj)+ 最小化/最大化/关闭。
       空白区域可拖动窗口,双击切换最大化(代码后置)。 -->

  <UserControl.Resources>

    <!-- 全局功能图标按钮(GQQwj):24×22,corner 3,hover bg-hover。 -->
    <ControlTheme x:Key="VelaTitleActionButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="22" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
      </Style>
      <Style Selector="^:disabled">
        <Setter Property="Opacity" Value="0.5" />
      </Style>
    </ControlTheme>

    <!-- 窗口控制按钮:46×35 命中区、无圆角,贴住窗口右上角。 -->
    <ControlTheme x:Key="VelaCaptionButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Width" Value="46" />
      <Setter Property="Height" Value="35" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Background="{TemplateBinding Background}"
                            Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
        </ControlTemplate>
      </Setter>
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
      </Style>
    </ControlTheme>

    <!-- 关闭按钮:hover 用系统红(图标转白见 UserControl.Styles —— ControlTheme
         不允许后代选择器)。 -->
    <ControlTheme x:Key="VelaCaptionCloseButton" TargetType="Button" BasedOn="{StaticResource VelaCaptionButton}">
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#E81123" />
      </Style>
    </ControlTheme>

  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Button.caption-close:pointerover pc|LucideIcon">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <!-- nc-hover:最大化按钮被非客户命中(HTMAXBUTTON,Win11 贴靠面板路径)时的
         悬停高亮 —— 此时指针事件不进 Avalonia,:pointerover 不生效,由
         MainWindow 的 WndProc 钩子按 NC 消息挂/摘该类。 -->
    <Style Selector="Button.nc-hover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
  </UserControl.Styles>

  <!-- 标题栏为纯客户区(不设 chrome 角色:Avalonia 12.0.5 的角色输入重定向在
       Win32 上未落地,角色区内的按钮点不动——实测)。拖动走 BeginMoveDrag
       (原生移动循环,Win11 边缘贴靠/拖顶最大化照常生效),双击切最大化。 -->
  <Border Height="36"
          Background="{DynamicResource VelaBgSidebar}"
          BorderBrush="{DynamicResource VelaBorderPrimary}"
          BorderThickness="0,0,0,1"
          PointerPressed="Bar_PointerPressed">
    <Grid ColumnDefinitions="Auto,*,Auto,Auto">

      <!-- 左:logo + 产品名(不参与命中,拖动透传到底层 Border)。 -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                  Margin="12,0" VerticalAlignment="Center" IsHitTestVisible="False">
        <Image Source="avares://VelaShell/Assets/velashell.png" Width="18" Height="18" />
        <TextBlock Text="{x:Static res:Strings.AppName}"
                   FontFamily="{DynamicResource VelaUiFont}"
                   FontSize="12" FontWeight="Medium"
                   Foreground="{DynamicResource VelaTextSecondary}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- 右:全局功能图标组(与命令注册表同源;广播已启用,组同步仍保持禁用)。 -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                  VerticalAlignment="Center" Margin="0,0,10,0">
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Menu_SearchTerminalTip}"
                Command="{Binding RunCommand}" CommandParameter="search.terminal">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.search}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Copy}"
                Command="{Binding RunCommand}" CommandParameter="edit.copy">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.copy}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Dock_SplitHorizontal}"
                Command="{Binding RunCommand}" CommandParameter="split.horizontal">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.columns-2}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Cmd_SftpFileManager}"
                Command="{Binding ToggleFileBrowserCommand}">
          <Panel>
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.folder-open}"
                           Foreground="{DynamicResource VelaTextMuted}"
                           IsVisible="{Binding !FileBrowser.IsVisible}" />
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.folder-open}"
                           Foreground="{DynamicResource VelaAccent}"
                           IsVisible="{Binding FileBrowser.IsVisible}" />
          </Panel>
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Menu_TunnelTip}"
                Command="{Binding RunCommand}" CommandParameter="tools.tunnel">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.route}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Menu_CommandPaletteTip}"
                Command="{Binding OpenCommandPaletteCommand}">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.zap}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize SyncGroup}" IsEnabled="False">
          <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.link-2}"
                         Foreground="{DynamicResource VelaTextMuted}" />
        </Button>
        <Button Theme="{StaticResource VelaTitleActionButton}"
                ToolTip.Tip="{loc:Localize Broadcast}"
                Command="{Binding RunCommand}" CommandParameter="terminal.broadcast">
          <Panel>
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.send}"
                           Foreground="{DynamicResource VelaTextMuted}"
                           IsVisible="{Binding !BroadcastInput.IsVisible}" />
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.send}"
                           Foreground="{DynamicResource VelaAccent}"
                           IsVisible="{Binding BroadcastInput.IsVisible}" />
          </Panel>
        </Button>
      </StackPanel>

      <!-- 窗口控制:最小化 / 最大化(还原) / 关闭(常规 Click,纯客户区必然可点)。 -->
      <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
        <Button Theme="{StaticResource VelaCaptionButton}" Click="Minimize_Click">
          <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.minus}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </Button>
        <Button x:Name="MaximizeButton" Theme="{StaticResource VelaCaptionButton}" Click="Maximize_Click">
          <pc:LucideIcon x:Name="MaximizeIcon" Width="11" Height="11" Data="{StaticResource Icon.square}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </Button>
        <Button Theme="{StaticResource VelaCaptionCloseButton}" Classes="caption-close" Click="Close_Click">
          <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.x}"
                         Foreground="{DynamicResource VelaTextTertiary}" />
        </Button>
      </StackPanel>

    </Grid>
  </Border>
</UserControl>
