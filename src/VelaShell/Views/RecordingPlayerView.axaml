<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VelaShell.ViewModels"
        xmlns:loc="using:VelaShell.Localization"
        x:Class="VelaShell.Views.RecordingPlayerView"
        x:DataType="vm:RecordingPlayerViewModel"
        Title="{loc:Localize Recorder_Title}"
        Width="1200" Height="820"
        MinWidth="860" MinHeight="600"
        CanResize="True"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <!-- 会话录制与回放(设计 NceE6):左栏最近录制列表,右栏终端回放 + 时间轴。 -->

  <Window.Styles>
    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderSecondary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.dlg-accent">
      <Setter Property="Background" Value="{DynamicResource VelaAccent}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaAccentForeground}" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-danger">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FF6B6B" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="10" />
    </Style>
    <!-- 录制列表:选中/悬停用主题令牌(与设置导航一致),替换 Fluent 默认的
         低对比蓝色选中背景;选中项标题以强调色突出。 -->
    <Style Selector="ListBox.rec-list">
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="ListBox.rec-list ListBoxItem">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Margin" Value="0,1" />
    </Style>
    <Style Selector="ListBox.rec-list ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="ListBox.rec-list ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgActive}" />
    </Style>
    <Style Selector="ListBox.rec-list ListBoxItem:selected:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgActive}" />
    </Style>
    <Style Selector="ListBox.rec-list ListBoxItem:selected TextBlock.rec-label">
      <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
    </Style>
  </Window.Styles>

  <Border CornerRadius="10"
          Background="{DynamicResource VelaBgSurface}"
          BorderBrush="{DynamicResource VelaBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12"
          ClipToBounds="True">
    <Grid RowDefinitions="56,*">

      <!-- 顶栏(可拖动,双击最大化/还原):标题 + 导出/自动录制/刷新/最大化/关闭 -->
      <Border Grid.Row="0" Padding="20,0"
              Background="Transparent"
              PointerPressed="Header_PointerPressed"
              DoubleTapped="Header_DoubleTapped"
              BorderBrush="{DynamicResource VelaBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="{loc:Localize Recorder_Title}"
                       Foreground="{DynamicResource VelaTextPrimary}"
                       FontSize="15" FontWeight="SemiBold" />
            <TextBlock Text="{loc:Localize Recorder_Subtitle}"
                       Foreground="{DynamicResource VelaTextMuted}"
                       FontFamily="{DynamicResource VelaTerminalFont}"
                       FontSize="10" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="dlg-outline" Content="{loc:Localize Recorder_Export}"
                    IsEnabled="{Binding HasSelection}"
                    Click="ExportRecording_Click"
                    ToolTip.Tip="{loc:Localize Recorder_ExportTip}" />
            <Button Classes="dlg-outline" Content="{loc:Localize Refresh}" Command="{Binding RefreshCommand}" />
            <Button Classes="dlg-accent" Content="{Binding AutoRecordText}"
                    Command="{Binding ToggleAutoRecordCommand}"
                    ToolTip.Tip="{loc:Localize Recorder_AutoRecordTip}" />
            <Button Width="26" Height="26" Background="Transparent" Padding="0"
                    CornerRadius="3" Cursor="Hand" Click="Maximize_Click"
                    VerticalAlignment="Center" ToolTip.Tip="{loc:Localize Recorder_MaximizeTip}">
              <TextBlock Text="▢" FontSize="12" HorizontalAlignment="Center"
                         Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
            <Button Width="26" Height="26" Background="Transparent" Padding="0"
                    CornerRadius="3" Cursor="Hand" Click="Close_Click"
                    VerticalAlignment="Center">
              <TextBlock Text="✕" FontSize="13" HorizontalAlignment="Center"
                         Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 主体:左列表 + 右回放 -->
      <Grid Grid.Row="1" ColumnDefinitions="300,16,*" Margin="20,16">

        <!-- 最近录制列表 -->
        <Border Grid.Column="0" CornerRadius="6"
                Background="{DynamicResource VelaBgInput}"
                BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="1">
          <Grid RowDefinitions="34,*">
            <Border Grid.Row="0" Padding="12,0"
                    BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1">
              <TextBlock Text="{loc:Localize Recorder_ListTitle}" FontSize="12" FontWeight="Medium"
                         Foreground="{DynamicResource VelaTextSecondary}" VerticalAlignment="Center" />
            </Border>
            <TextBlock Grid.Row="1" Margin="12" TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource VelaTextMuted}"
                       Text="{loc:Localize Recorder_Empty}"
                       IsVisible="{Binding !HasRecordings}" />
            <ListBox Grid.Row="1" Classes="rec-list" Background="Transparent"
                     ItemsSource="{Binding Recordings}"
                     SelectedItem="{Binding SelectedRecording}"
                     IsVisible="{Binding HasRecordings}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RecordingItemViewModel">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="2">
                      <TextBlock Classes="rec-label" FontSize="12" FontWeight="Medium"
                                 Foreground="{DynamicResource VelaTextPrimary}"
                                 Text="{Binding Label}" />
                      <TextBlock FontSize="10"
                                 FontFamily="{DynamicResource VelaTerminalFont}"
                                 Foreground="{DynamicResource VelaTextMuted}">
                        <Run Text="{Binding StartText, Mode=OneWay}" />
                        <Run Text=" • " /><Run Text="{Binding DurationText, Mode=OneWay}" />
                        <Run Text=" • " /><Run Text="{Binding SizeText, Mode=OneWay}" />
                      </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Classes="dlg-danger" Content="{loc:Localize Delete}"
                            VerticalAlignment="Center"
                            Command="{Binding $parent[ListBox].((vm:RecordingPlayerViewModel)DataContext).DeleteCommand}"
                            CommandParameter="{Binding}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <!-- 回放面板 -->
        <Border Grid.Column="2" CornerRadius="6"
                Background="{DynamicResource VelaBgInput}"
                BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="1">
          <Grid RowDefinitions="34,*,Auto,Auto">
            <Border Grid.Row="0" Padding="12,0"
                    BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1">
              <TextBlock FontSize="12" FontWeight="Medium"
                         Foreground="{DynamicResource VelaTextSecondary}" VerticalAlignment="Center"
                         Text="{Binding PlaybackTitle}" />
            </Border>

            <!-- 终端回放区(VelaTerminalControl 由代码后置挂载) -->
            <Border Grid.Row="1" x:Name="TerminalHost" Margin="8" ClipToBounds="True" />

            <!-- 时间轴 -->
            <Grid Grid.Row="2" Margin="12,4" ColumnDefinitions="Auto,8,*,8,Auto">
              <TextBlock Grid.Column="0" FontSize="10" VerticalAlignment="Center"
                         FontFamily="{DynamicResource VelaTerminalFont}"
                         Foreground="{DynamicResource VelaTextMuted}"
                         Text="{Binding PositionText}" />
              <Slider Grid.Column="2" Minimum="0" VerticalAlignment="Center"
                      Maximum="{Binding DurationMs}"
                      Value="{Binding PositionMs}" />
              <TextBlock Grid.Column="4" FontSize="10" VerticalAlignment="Center"
                         FontFamily="{DynamicResource VelaTerminalFont}"
                         Foreground="{DynamicResource VelaTextMuted}"
                         Text="{Binding DurationText}" />
            </Grid>

            <!-- 控制条 -->
            <Grid Grid.Row="3" Margin="12,0,12,10" ColumnDefinitions="Auto,8,Auto,8,Auto,*,Auto">
              <Button Grid.Column="0" Classes="dlg-accent" Width="72"
                      Content="{Binding PlayButtonText}"
                      Command="{Binding TogglePlayCommand}"
                      IsEnabled="{Binding HasSelection}" />
              <Button Grid.Column="2" Classes="dlg-outline" Width="48"
                      Content="{Binding SpeedText}" Click="CycleSpeed_Click"
                      ToolTip.Tip="{loc:Localize Recorder_SpeedTip}" />
              <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <ToggleSwitch IsChecked="{Binding SkipIdle}" Padding="0" MinWidth="0"
                              OnContent="" OffContent="" />
                <TextBlock Text="{loc:Localize Recorder_SkipIdle}" FontSize="11" VerticalAlignment="Center"
                           Foreground="{DynamicResource VelaTextSecondary}" />
              </StackPanel>
              <TextBlock Grid.Column="6" FontSize="10" VerticalAlignment="Center"
                         Foreground="{DynamicResource VelaTextMuted}"
                         TextWrapping="Wrap" MaxWidth="320"
                         Text="{Binding Status}" />
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <!-- 右下角缩放手柄:无边框窗口没有系统缩放边缘,拖动此处调整窗口大小。 -->
      <Border Grid.Row="1" Width="20" Height="20" ZIndex="10"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Background="Transparent" Cursor="BottomRightCorner"
              PointerPressed="ResizeGrip_PointerPressed"
              ToolTip.Tip="{loc:Localize Recorder_ResizeTip}">
        <Path Data="M14,4 L4,14 M14,9 L9,14"
              Stroke="{DynamicResource VelaTextMuted}" StrokeThickness="1.5"
              Margin="0,0,3,3" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
      </Border>
    </Grid>
  </Border>
</Window>
