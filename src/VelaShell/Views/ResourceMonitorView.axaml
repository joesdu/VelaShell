<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:loc="using:VelaShell.Localization"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="220"
             x:Class="VelaShell.Views.ResourceMonitorView"
             x:DataType="vm:ResourceMonitorViewModel">

  <!-- 资源面板(设计帧 EP3Gd,规范 §11):宽 280px,内边距 12,间距 8;进度条高 6px、
       圆角 3,底色为 bg-active;CPU=终端蓝,RAM=终端黄,Disk=终端绿;
       超过 70% 转警告色,超过 90% 转错误色。嵌入标签悬停提示气泡中。 -->

  <UserControl.Styles>
    <Style Selector="TextBlock.row-label">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="TextBlock.row-value">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Height" Value="6" />
      <Setter Property="MinHeight" Value="6" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Background" Value="{DynamicResource VelaBgActive}" />
      <Setter Property="Minimum" Value="0" />
      <Setter Property="Maximum" Value="100" />
    </Style>
    <Style Selector="ProgressBar.warn">
      <Setter Property="Foreground" Value="{DynamicResource VelaWarning}" />
    </Style>
    <Style Selector="ProgressBar.crit">
      <Setter Property="Foreground" Value="{DynamicResource VelaError}" />
    </Style>
    <Style Selector="TextBlock.info-label">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
      <Setter Property="FontSize" Value="10" />
    </Style>
    <Style Selector="TextBlock.info-value">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaUiFont}" />
      <Setter Property="FontSize" Value="10" />
    </Style>
  </UserControl.Styles>

  <StackPanel Width="256" Margin="12" Spacing="8">

    <!-- 头部:主机名 + 延迟 -->
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="{Binding HostName}"
                 Foreground="{DynamicResource VelaTextPrimary}"
                 FontFamily="{DynamicResource VelaUiFont}"
                 FontSize="13" FontWeight="Bold" />
    </Grid>

    <!-- 不可用占位(§11:若该会话已断开，显示数据不可用) -->
    <TextBlock Text="{loc:Localize Monitor_Unavailable}"
               Foreground="{DynamicResource VelaTextMuted}"
               FontFamily="{DynamicResource VelaUiFont}" FontSize="11"
               IsVisible="{Binding !IsAvailable}" />

    <StackPanel Spacing="8" IsVisible="{Binding IsAvailable}">

      <!-- CPU -->
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="row-label" Text="{Binding CpuLabel}" />
          <TextBlock Grid.Column="1" Classes="row-value" Text="{Binding CpuText}" />
        </Grid>
        <ProgressBar Value="{Binding CpuPercent}"
                     Foreground="{DynamicResource VelaShellBlue}"
                     Classes.warn="{Binding CpuWarn}" Classes.crit="{Binding CpuCrit}" />
      </StackPanel>

      <!-- RAM -->
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="row-label" Text="RAM" />
          <TextBlock Grid.Column="1" Classes="row-value" Text="{Binding RamText}" />
        </Grid>
        <ProgressBar Value="{Binding RamPercent}"
                     Foreground="{DynamicResource VelaShellYellow}"
                     Classes.warn="{Binding RamWarn}" Classes.crit="{Binding RamCrit}" />
      </StackPanel>

      <!-- Disk:一盘一行(多磁盘主机全部显示);拿不到列表时 VM 退回单行聚合。 -->
      <ItemsControl ItemsSource="{Binding Disks}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="8" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DiskRowViewModel">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="row-label" Text="{Binding Label}"
                           TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                <TextBlock Grid.Column="1" Classes="row-value" Text="{Binding Text}" />
              </Grid>
              <ProgressBar Value="{Binding Percent}"
                           Foreground="{DynamicResource VelaShellGreen}"
                           Classes.warn="{Binding Warn}" Classes.crit="{Binding Crit}" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- 系统信息 -->
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="info-label" Text="{loc:Localize Monitor_OsVersion}" />
          <TextBlock Grid.Column="1" Classes="info-value" Text="{Binding OsVersion}" />
        </Grid>
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="info-label" Text="{loc:Localize Monitor_Kernel}" />
          <TextBlock Grid.Column="1" Classes="info-value" Text="{Binding Kernel}" />
        </Grid>
      </StackPanel>

    </StackPanel>
  </StackPanel>
</UserControl>
