<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VelaShell.ViewModels"
        xmlns:pc="using:VelaShell.Controls.Controls"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="480"
        x:Class="VelaShell.Views.ConnectionDiagnosticsView"
        x:DataType="vm:ConnectionDiagnosticsViewModel"
        Title="连接诊断"
        Width="760" Height="480"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <!-- 连接诊断中心,布局对齐设计帧 RGXg1:头部(标题 + 导出/重新检测),
       左侧诊断步骤面板,右侧发现问题 + 修复建议。 -->

  <Window.Styles>
    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderPrimary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-primary">
      <Setter Property="Background" Value="{DynamicResource VelaAccent}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaAccentForeground}" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <!-- 步骤行状态配色 -->
    <Style Selector="TextBlock.step-status">
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </Window.Styles>

  <Border CornerRadius="8"
          Background="{DynamicResource VelaBgSurface}"
          BorderBrush="{DynamicResource VelaBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12">
    <DockPanel>

      <!-- Header (design diagHeader):可拖动 + 标题/副标题 | 导出/重新检测/关闭 -->
      <Border DockPanel.Dock="Top" Height="60" Padding="20,0"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource VelaBorderPrimary}"
              Background="Transparent"
              PointerPressed="Header_PointerPressed">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <pc:LucideIcon Width="15" Height="15"
                             Data="{StaticResource Icon.stethoscope}"
                             Foreground="{DynamicResource VelaAccent}" VerticalAlignment="Center" />
              <TextBlock Text="连接诊断中心"
                         Foreground="{DynamicResource VelaTextPrimary}"
                         FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding TargetSummary}"
                       Foreground="{DynamicResource VelaTextMuted}"
                       FontFamily="{DynamicResource VelaTerminalFont}"
                       FontSize="10" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="dlg-outline" Click="ExportReport_Click"
                    IsEnabled="{Binding CanExport}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <pc:LucideIcon Width="11" Height="11"
                               Data="{StaticResource Icon.download}"
                               Foreground="{DynamicResource VelaTextSecondary}" VerticalAlignment="Center" />
                <TextBlock Text="导出诊断报告" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="dlg-primary" Command="{Binding RunCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <pc:LucideIcon Width="11" Height="11"
                               Data="{StaticResource Icon.refresh-cw}"
                               Foreground="{DynamicResource VelaAccentForeground}" VerticalAlignment="Center" />
                <TextBlock Text="重新检测" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Width="28" Height="28" Padding="0" CornerRadius="4"
                    Background="Transparent" Cursor="Hand" Click="Close_Click"
                    ToolTip.Tip="关闭">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.x}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Body (design diagBody): 左步骤面板 + 右问题面板 -->
      <Grid Margin="20,16" ColumnDefinitions="320,16,*">

        <!-- 诊断步骤 (design stepPanel) -->
        <Border Grid.Column="0"
                Background="{DynamicResource VelaBgPrimary}"
                BorderBrush="{DynamicResource VelaBorderPrimary}"
                BorderThickness="1" CornerRadius="6">
          <DockPanel>
            <Border DockPanel.Dock="Top" Height="34" Padding="12,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource VelaBorderPrimary}">
              <TextBlock Text="诊断步骤"
                         Foreground="{DynamicResource VelaTextSecondary}"
                         FontSize="12" FontWeight="Medium" VerticalAlignment="Center" />
            </Border>
            <ItemsControl ItemsSource="{Binding Steps}" Margin="12,10">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DiagnosticStepItemViewModel">
                  <StackPanel Margin="0,0,0,12" Spacing="3">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding DisplayName}"
                                 Classes="step-status"
                                 Foreground="{DynamicResource VelaTextPrimary}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding StatusText}"
                                 Classes="step-status"
                                 Classes.st-ok="{Binding IsSuccess}"
                                 Classes.st-warn="{Binding IsWarning}"
                                 Classes.st-fail="{Binding IsFailed}"
                                 Classes.st-muted="{Binding IsMuted}"
                                 Classes.st-running="{Binding IsRunning}">
                        <TextBlock.Styles>
                          <Style Selector="TextBlock.st-ok">
                            <Setter Property="Foreground" Value="{DynamicResource VelaStatusConnected}" />
                          </Style>
                          <Style Selector="TextBlock.st-warn">
                            <Setter Property="Foreground" Value="{DynamicResource VelaWarning}" />
                          </Style>
                          <Style Selector="TextBlock.st-fail">
                            <Setter Property="Foreground" Value="{DynamicResource VelaError}" />
                          </Style>
                          <Style Selector="TextBlock.st-muted">
                            <Setter Property="Foreground" Value="{DynamicResource VelaTextMuted}" />
                          </Style>
                          <Style Selector="TextBlock.st-running">
                            <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
                          </Style>
                        </TextBlock.Styles>
                      </TextBlock>
                    </Grid>
                    <TextBlock Text="{Binding Detail}"
                               IsVisible="{Binding HasDetail}"
                               Foreground="{DynamicResource VelaTextMuted}"
                               FontFamily="{DynamicResource VelaTerminalFont}"
                               FontSize="10" TextWrapping="Wrap"
                               Margin="14,0,0,0" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </Border>

        <!-- 发现问题 + 修复建议 (design issuePanel) -->
        <Border Grid.Column="2"
                Background="{DynamicResource VelaBgPrimary}"
                BorderBrush="{DynamicResource VelaBorderPrimary}"
                BorderThickness="1" CornerRadius="6"
                Padding="14,12">
          <StackPanel Spacing="10">

            <!-- 检测中占位 -->
            <TextBlock Text="// 正在逐项检测,请稍候…"
                       IsVisible="{Binding IsBusy}"
                       Foreground="{DynamicResource VelaTextMuted}"
                       FontFamily="{DynamicResource VelaTerminalFont}" FontSize="11" />

            <!-- 未发现问题 -->
            <Border Background="{DynamicResource VelaBgSurface}"
                    CornerRadius="6" Padding="12,10"
                    IsVisible="{Binding AllPassed}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <pc:LucideIcon Width="13" Height="13"
                               Data="{StaticResource Icon.circle-check}"
                               Foreground="{DynamicResource VelaStatusConnected}" VerticalAlignment="Center" />
                <TextBlock Text="未发现问题,各项检测均通过,可正常连接。"
                           Foreground="{DynamicResource VelaStatusConnected}"
                           FontSize="12" FontWeight="Medium" VerticalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- 问题卡片 (design issueCard) -->
            <Border Background="{DynamicResource VelaBgSurface}"
                    CornerRadius="6" Padding="12,10"
                    IsVisible="{Binding HasIssue}">
              <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <pc:LucideIcon Width="13" Height="13"
                                 Data="{StaticResource Icon.triangle-alert}"
                                 Foreground="{DynamicResource VelaWarning}" VerticalAlignment="Center" />
                  <TextBlock Foreground="{DynamicResource VelaWarning}"
                             FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Run Text="发现问题:" /><Run Text="{Binding IssueTitle}" />
                  </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding IssueDescription}"
                           Foreground="{DynamicResource VelaTextSecondary}"
                           FontSize="11" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <!-- 修复建议 (design fixList) -->
            <ItemsControl ItemsSource="{Binding Suggestions}"
                          IsVisible="{Binding Suggestions.Count}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="2,0,0,8">
                    <pc:LucideIcon Width="11" Height="11"
                                   Data="{StaticResource Icon.info}"
                                   Foreground="{DynamicResource VelaAccent}"
                                   VerticalAlignment="Top" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding}"
                               Foreground="{DynamicResource VelaTextPrimary}"
                               FontSize="11" TextWrapping="Wrap"
                               MaxWidth="330" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </Border>
      </Grid>
    </DockPanel>
  </Border>
</Window>
