<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:pc="using:VelaShell.Controls.Controls"
             xmlns:loc="using:VelaShell.Localization"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="160"
             x:Class="VelaShell.Views.FileTransferView"
             x:DataType="vm:FileTransferViewModel">

  <!-- 浮动传输提示(设计帧 9Ralg):宽 280px,bg-surface,圆角 6,
       1px border-secondary,阴影 blur16 y+4。仅在有传输时存在;
       全部完成后约 3s 自动淡出;x 收起而不取消(规范 §9)。 -->

  <Border Width="280"
          Background="{DynamicResource VelaBgSurface}"
          BorderBrush="{DynamicResource VelaBorderSecondary}"
          BorderThickness="1"
          CornerRadius="6"
          BoxShadow="0 4 16 0 #60000000"
          IsVisible="{Binding IsPanelVisible}">
    <StackPanel>

      <!-- 表头(32px,拖拽手柄):arrow-up-down 强调色 + 传输 + 数量徽标 | x -->
      <Border Height="32"
              Padding="12,0"
              BorderBrush="{DynamicResource VelaBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <pc:LucideIcon Width="12" Height="12"
                           Data="{StaticResource Icon.arrow-up-down}"
                           Foreground="{DynamicResource VelaAccent}" />
            <TextBlock Text="{loc:Localize Transfer_Title}"
                       Foreground="{DynamicResource VelaTextPrimary}"
                       FontFamily="{DynamicResource VelaTerminalFont}"
                       FontSize="11" FontWeight="Medium"
                       VerticalAlignment="Center" />
            <Border Background="{DynamicResource VelaAccent}"
                    CornerRadius="8" Padding="6,1"
                    VerticalAlignment="Center"
                    IsVisible="{Binding PendingCount}">
              <TextBlock Text="{Binding PendingCount}"
                         Foreground="{DynamicResource VelaAccentText}"
                         FontFamily="{DynamicResource VelaTerminalFont}"
                         FontSize="9" FontWeight="Medium" />
            </Border>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <!-- 取消正在运行的批次中剩余的文件(中止当前进行中的那一个)。 -->
            <Button Background="Transparent" Padding="4,1" Cursor="Hand"
                    IsVisible="{Binding IsBatchActive}"
                    Command="{Binding CancelAllCommand}"
                    ToolTip.Tip="{loc:Localize Transfer_CancelRemainingTip}">
              <TextBlock Text="{loc:Localize Cancel}"
                         Foreground="{DynamicResource VelaError}"
                         FontFamily="{DynamicResource VelaTerminalFont}"
                         FontSize="10" FontWeight="Medium" />
            </Button>
            <Button Background="Transparent" Padding="2" Cursor="Hand"
                    Command="{Binding HidePanelCommand}"
                    ToolTip.Tip="{loc:Localize Transfer_CollapseTip}">
              <pc:LucideIcon Width="12" Height="12"
                             Data="{StaticResource Icon.x}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 准备中:选择大文件夹后目录扫描的即时反馈,头部徽标随发现数递增。 -->
      <Border Padding="12,8"
              BorderBrush="{DynamicResource VelaBorderPrimary}"
              BorderThickness="0,0,0,1"
              IsVisible="{Binding IsPreparing}">
        <TextBlock Text="{Binding PreparingText}"
                   Foreground="{DynamicResource VelaTextMuted}"
                   FontFamily="{DynamicResource VelaTerminalFont}"
                   FontSize="10" />
      </Border>

      <!-- 传输行:限制面板高度(约 5 行)并对溢出内容滚动。 -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    MaxHeight="280">
        <ItemsControl ItemsSource="{Binding Transfers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:TransferItemViewModel">
              <Border Padding="12,8"
                      BorderBrush="{DynamicResource VelaBorderPrimary}"
                      BorderThickness="0,0,0,1">
                <StackPanel Spacing="4">

                  <!-- 名称 / 百分比 -->
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding FileName}"
                               Foreground="{DynamicResource VelaTextPrimary}"
                               FontFamily="{DynamicResource VelaTerminalFont}"
                               FontSize="10" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressText}"
                               FontFamily="{DynamicResource VelaTerminalFont}"
                               FontSize="10" FontWeight="Medium"
                               Classes.done="{Binding IsCompleted}"
                               Classes.failed="{Binding IsFailed}">
                      <TextBlock.Styles>
                        <Style Selector="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
                        </Style>
                        <Style Selector="TextBlock.done">
                          <Setter Property="Foreground" Value="{DynamicResource VelaStatusConnected}" />
                        </Style>
                        <Style Selector="TextBlock.failed">
                          <Setter Property="Foreground" Value="{DynamicResource VelaError}" />
                        </Style>
                      </TextBlock.Styles>
                    </TextBlock>
                  </Grid>

                  <!-- 进度条:3px 轨道 border-primary + 强调色填充 -->
                  <ProgressBar Minimum="0" Maximum="100"
                               Value="{Binding Progress}"
                               Height="3" MinHeight="3"
                               CornerRadius="2"
                               Background="{DynamicResource VelaBorderPrimary}"
                               Foreground="{DynamicResource VelaAccent}" />

                  <!-- 明细行 -->
                  <TextBlock Text="{Binding InfoLine}"
                             Foreground="{DynamicResource VelaTextMuted}"
                             FontFamily="{DynamicResource VelaTerminalFont}"
                             FontSize="9" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </StackPanel>
  </Border>
</UserControl>
