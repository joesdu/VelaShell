<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:VelaShell.ViewModels"
        xmlns:behaviors="using:VelaShell.Behaviors"
        xmlns:models="clr-namespace:VelaShell.Core.Models;assembly=VelaShell.Core"
        xmlns:loc="using:VelaShell.Localization"
        mc:Ignorable="d" d:DesignWidth="500"
        x:Class="VelaShell.Views.ConnectionProfileView"
        x:DataType="vm:ConnectionProfileViewModel"
        Title="{loc:Localize Profile_Title}"
        Width="500"
        SizeToContent="Height"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">
  <Window.Styles>
    <Style Selector="AdornerLayer">
      <Setter Property="DefaultFocusAdorner" Value="{x:Null}" />
    </Style>
    <!-- 表单标签 -->
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Margin" Value="0,0,0,5" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource VelaBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource VelaBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="{DynamicResource VelaBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
    </Style>
    <!-- 底部按钮:描边(测试/保存)与主色(连接) -->
    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaBorderPrimary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-primary">
      <Setter Property="Background" Value="{DynamicResource VelaAccent}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaAccentForeground}" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <!-- 协议标签页 -->
    <Style Selector="Border.proto-tab">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
    </Style>
    <Style Selector="TextBlock.proto-label">
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.proto-tab">
      <Setter Property="FocusAdorner" Value="{x:Null}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextTertiary}" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Height" Value="32" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.proto-tab:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource VelaTextSecondary}" />
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="Button.proto-tab.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource VelaAccent}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
    </Style>
    <!-- Avalonia's :focus state is the keyboard-focus hook for this control. Keep the
         selected underline hierarchy intact; the tokenized focus fill is the additional
         keyboard affordance. -->
    <Style Selector="Button.proto-tab:focus">
      <Setter Property="Background" Value="{DynamicResource VelaAccentDim}" />
    </Style>
    <!-- Fluent's focus layer is above the Button background; override only this
         class so its system accent cannot replace the Vela focus token. -->
    <Style Selector="Button.proto-tab:focus /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaAccentDim}" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaAccent}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.proto-tab:focus /template/ Border#PART_FocusAdorner">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource VelaAccent}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
  </Window.Styles>

  <!-- 自绘对话框卡片(设计:圆角 8、外描边、投影) -->
  <Border CornerRadius="8"
          Background="{DynamicResource VelaBgSurface}"
          BorderBrush="{DynamicResource VelaBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12">
    <StackPanel>

      <!-- Header: plug 图标 + 标题 + 关闭 -->
      <Border Height="48" Padding="20,0"
              PointerPressed="Header_PointerPressed"
              Background="Transparent"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource VelaBorderPrimary}">
        <Grid ColumnDefinitions="Auto,8,*,Auto">
          <PathIcon Grid.Column="0" Width="16" Height="16"
                    Data="M16 7V3h-2v4h-4V3H8v4c-1.1 0-2 .9-2 2v5.5L9.5 18v3h5v-3L18 14.5V9c0-1.1-.9-2-2-2z"
                    Foreground="{DynamicResource VelaAccent}"
                    VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{loc:Localize Profile_Title}"
                     Foreground="{DynamicResource VelaTextPrimary}"
                     FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="3" Width="24" Height="24"
                  Background="Transparent" Padding="0" CornerRadius="3"
                  Cursor="Hand" Command="{Binding CancelCommand}">
            <PathIcon Width="14" Height="14"
                      Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                      Foreground="{DynamicResource VelaTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- 协议标签页:SSH/SFTP 可选;Telnet/串口保持禁用 -->
      <Border Height="36" Padding="20,0"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource VelaBorderPrimary}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
          <Button Classes="proto-tab" Classes.selected="{Binding IsSshSelected}"
                  Command="{Binding SelectConnectionTypeCommand}"
                  CommandParameter="{x:Static models:ConnectionType.SSH}">
            <TextBlock Classes="proto-label" Text="SSH" FontWeight="Medium" />
          </Button>
          <Button Classes="proto-tab" Classes.selected="{Binding IsSftpSelected}"
                  Command="{Binding SelectConnectionTypeCommand}"
                  CommandParameter="{x:Static models:ConnectionType.SFTP}">
            <TextBlock Classes="proto-label" Text="SFTP" FontWeight="Medium" />
          </Button>
          <Border Classes="proto-tab" IsEnabled="False" ToolTip.Tip="{loc:Localize Profile_NotSupported}">
            <TextBlock Classes="proto-label" Text="Telnet"
                       Foreground="{DynamicResource VelaTextTertiary}" />
          </Border>
          <Border Classes="proto-tab" IsEnabled="False" ToolTip.Tip="{loc:Localize Profile_NotSupported}">
            <TextBlock Classes="proto-label" Text="{loc:Localize Profile_Serial}"
                       Foreground="{DynamicResource VelaTextTertiary}" />
          </Border>
        </StackPanel>
      </Border>

      <!-- 表单 -->
      <StackPanel Margin="20,18" Spacing="14">

        <!-- 主机名/IP + 端口 -->
        <Grid ColumnDefinitions="*,12,90">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="{loc:Localize Profile_HostIp}" />
            <TextBox Text="{Binding Host}" PlaceholderText="192.168.1.100" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="{loc:Localize Port}" />
            <NumericUpDown Value="{Binding Port}" Minimum="1" Maximum="65535"
                           Increment="1" FormatString="0" ShowButtonSpinner="False" />
          </StackPanel>
        </Grid>

        <!-- 用户名 + 认证方式 -->
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="{loc:Localize Username}" />
            <TextBox Text="{Binding Username}" PlaceholderText="root" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="{loc:Localize AuthMethodLabel}" />
            <ComboBox SelectedIndex="{Binding AuthMethodIndex}">
              <ComboBoxItem Content="{loc:Localize Profile_PasswordAuth}" />
              <ComboBoxItem Content="{loc:Localize Profile_KeyAuth}" />
            </ComboBox>
          </StackPanel>
        </Grid>

        <!-- 密码(密码认证) -->
        <StackPanel IsVisible="{Binding IsPasswordAuth}">
          <TextBlock Classes="field-label" Text="{loc:Localize Password}" />
          <Border Classes="input-affix">
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0"
                       behaviors:SecurePasswordBox.Enabled="True"
                       behaviors:SecurePasswordBox.Password="{Binding Password}"
                       behaviors:SecurePasswordBox.Reveal="{Binding ShowPassword}"
                       Padding="10,0,0,0"
                       VerticalAlignment="Center" />
              <Button Grid.Column="1" Width="28" Height="28"
                      Margin="0,0,2,0" Padding="0"
                      Background="Transparent" CornerRadius="3" Cursor="Hand"
                      Command="{Binding TogglePasswordVisibilityCommand}"
                      ToolTip.Tip="{loc:Localize Profile_ShowHidePassword}"
                      VerticalAlignment="Center">
                <PathIcon Width="13" Height="13"
                          Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                          Foreground="{DynamicResource VelaTextTertiary}" />
              </Button>
            </Grid>
          </Border>
        </StackPanel>

        <!-- 私钥(密钥认证) -->
        <StackPanel IsVisible="{Binding IsKeyAuth}" Spacing="14">
          <StackPanel>
            <TextBlock Classes="field-label" Text="{loc:Localize Profile_PrivateKeyFile}" />
            <Grid ColumnDefinitions="*,8,Auto">
              <TextBox Grid.Column="0" Text="{Binding PrivateKeyPath}"
                       PlaceholderText="~/.ssh/id_ed25519" />
              <Button Grid.Column="2" Classes="dlg-outline"
                      Content="{loc:Localize BrowseKeyFile}" Click="BrowseKeyFile_Click" />
            </Grid>
          </StackPanel>
          <StackPanel>
            <TextBlock Classes="field-label" Text="{loc:Localize Profile_PassphraseOptional}" />
            <TextBox Text="{Binding PrivateKeyPassphrase}"
                     PasswordChar="&#x2022;" RevealPassword="False" />
          </StackPanel>
        </StackPanel>

        <!-- 记住密码 -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    IsVisible="{Binding IsPasswordAuth}">
          <CheckBox IsChecked="{Binding RememberPassword}"
                    Padding="0" MinHeight="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Localize Profile_RememberPassword}"
                       Margin="6,0,0,0"
                       Foreground="{DynamicResource VelaTextSecondary}"
                       FontSize="11" FontWeight="Medium" />
          </CheckBox>
          <TextBlock Text="{loc:Localize Profile_AesNote}"
                     Foreground="{DynamicResource VelaTextMuted}"
                     FontFamily="{DynamicResource VelaTerminalFont}"
                     FontSize="10"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- 会话分组 + 显示名称 -->
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="{loc:Localize Profile_SessionGroup}" />
            <!-- 可编辑下拉:选已有分组,或直接输入新分组名(保存时不存在则自动建组)。 -->
            <ComboBox IsEditable="True"
                      ItemsSource="{Binding Groups}"
                      SelectedItem="{Binding SelectedGroup}"
                      Text="{Binding GroupText}"
                      PlaceholderText="{loc:Localize Profile_GroupPlaceholder}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="{loc:Localize Profile_DisplayName}" />
            <TextBox Text="{Binding Name}" PlaceholderText="web-prod-03" />
          </StackPanel>
        </Grid>

        <!-- 高级选项内容 -->
        <StackPanel IsVisible="{Binding IsAdvancedVisible}" Spacing="4">
          <TextBlock Classes="field-label" Text="{loc:Localize Profile_TagsLabel}" />
          <TextBox Text="{Binding TagsText}" PlaceholderText="{loc:Localize Profile_TagsPlaceholder}" />
          <TextBlock Classes="field-label" Text="{loc:Localize Profile_JumpHost}" Margin="0,8,0,0" />
          <ComboBox HorizontalAlignment="Stretch"
                    ItemsSource="{Binding JumpHostOptions}"
                    SelectedItem="{Binding SelectedJumpHost}" />
          <TextBlock Text="{loc:Localize Profile_JumpHostHint}"
                     Foreground="{DynamicResource VelaTextMuted}" FontSize="10" TextWrapping="Wrap" />
        </StackPanel>

        <!-- 测试/保存反馈 -->
        <TextBlock Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="#FF6B6B" FontSize="11" TextWrapping="Wrap" />
        <TextBlock Text="{loc:Localize Profile_TestSuccess}"
                   IsVisible="{Binding ShowTestSuccess}"
                   Foreground="{DynamicResource VelaAccent}" FontSize="11" />
      </StackPanel>

      <!-- Footer -->
      <Border Height="52" Padding="20,0"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource VelaBorderPrimary}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- 高级选项开关 -->
          <Button Grid.Column="0" Background="Transparent" Padding="0"
                  Cursor="Hand" Command="{Binding ToggleAdvancedCommand}"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Width="12" Height="12"
                        Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"
                        Foreground="{DynamicResource VelaTextTertiary}" />
              <TextBlock Text="{loc:Localize Profile_AdvancedOptions}"
                         Foreground="{DynamicResource VelaTextTertiary}"
                         FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Button Classes="dlg-outline" Command="{Binding TestConnectionCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M11 21h-1l1-7H7.5c-.58 0-.57-.32-.38-.66.19-.34.05-.08.07-.12C8.48 10.94 10.42 7.54 13 3h1l-1 7h3.5c.49 0 .56.33.47.51l-.07.15C12.96 17.55 11 21 11 21z"
                          Foreground="{DynamicResource VelaTextSecondary}" />
                <TextBlock Text="{loc:Localize Profile_Test}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="dlg-outline" Command="{Binding SaveCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                          Foreground="{DynamicResource VelaTextSecondary}" />
                <TextBlock Text="{loc:Localize Save}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="dlg-primary" Command="{Binding ConnectCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M16 7V3h-2v4h-4V3H8v4c-1.1 0-2 .9-2 2v5.5L9.5 18v3h5v-3L18 14.5V9c0-1.1-.9-2-2-2z"
                          Foreground="{DynamicResource VelaAccentForeground}" />
                <TextBlock Text="{loc:Localize Connect}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

    </StackPanel>
  </Border>
</Window>
