<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:views="using:VelaShell.Views"
             xmlns:pc="using:VelaShell.Controls.Controls"
             xmlns:res="clr-namespace:VelaShell.Core.Resources;assembly=VelaShell.Core"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="VelaShell.Views.SftpDocumentView"
             x:DataType="vm:SftpDocumentViewModel">
  <Border Background="{DynamicResource VelaBgTerminal}">
    <DockPanel>
      <Border DockPanel.Dock="Top" Height="36" Padding="14,0"
              Background="{DynamicResource VelaBgSidebar}"
              BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <pc:LucideIcon Width="14" Height="14" Data="{StaticResource Icon.folder-open}"
                           Foreground="{DynamicResource VelaAccent}" />
            <TextBlock Text="{Binding Title}" FontFamily="{DynamicResource VelaTerminalFont}" FontSize="11"
                       FontWeight="Medium" Foreground="{DynamicResource VelaTextPrimary}" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
            <Button x:Name="LocalRefreshButton" Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    ToolTip.Tip="{x:Static res:Strings.SftpLocalRefresh}"
                    AutomationProperties.Name="{x:Static res:Strings.SftpLocalRefresh}"
                    Command="{Binding LocalFiles.RefreshCommand}">
              <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.refresh-cw}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
            <Button x:Name="RemoteRefreshButton" Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    ToolTip.Tip="{x:Static res:Strings.SftpRemoteRefresh}"
                    AutomationProperties.Name="{x:Static res:Strings.SftpRemoteRefresh}"
                    Command="{Binding RemoteFiles.RefreshCommand}">
              <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.refresh-cw}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>
      <Grid MinWidth="564">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="280" />
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" MinWidth="280" />
        </Grid.ColumnDefinitions>
        <views:LocalFilePaneView Grid.Column="0" DataContext="{Binding LocalFiles}" />
        <GridSplitter Grid.Column="1" Background="{DynamicResource VelaBorderPrimary}"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />
        <views:FileBrowserView Grid.Column="2" DataContext="{Binding RemoteFiles}" />
      </Grid>
    </DockPanel>
  </Border>
</UserControl>
