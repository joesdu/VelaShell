<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:res="clr-namespace:VelaShell.Core.Resources;assembly=VelaShell.Core"
             xmlns:loc="using:VelaShell.Localization"
             xmlns:pc="using:VelaShell.Controls.Controls"
             mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="400"
             x:Class="VelaShell.Views.LocalFilePaneView"
             x:DataType="vm:LocalFilePaneViewModel">
  <UserControl.Styles>
    <Style Selector="Button.toolbar-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="Border.file-row:pointerover">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="Border.file-row.parent">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="0" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
    </Style>
    <Style Selector="Button.crumb">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2,1" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource VelaTextPrimary}" />
      <Setter Property="FontFamily" Value="{DynamicResource VelaTerminalFont}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.crumb:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource VelaBgHover}" />
      <Setter Property="Foreground" Value="{DynamicResource VelaAccent}" />
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource VelaBgTerminal}"
          BorderBrush="{DynamicResource VelaBorderPrimary}"
          BorderThickness="0,1,0,0">
    <DockPanel>
      <Border DockPanel.Dock="Top" Height="36" Padding="14,0"
              BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
          <Grid Grid.Column="0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" ClipToBounds="True">
              <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.hard-drive}"
                             Foreground="{DynamicResource VelaTextTertiary}" VerticalAlignment="Center" />
              <!-- 可点击面包屑分段,风格与远端 FileBrowserView 一致 -->
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ClipToBounds="True">
                <Button Classes="crumb" Content="{Binding RootBreadcrumbLabel}"
                        Command="{Binding NavigateToCommand}"
                        CommandParameter="{Binding RootBreadcrumbPath}" />
                <ItemsControl ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LocalBreadcrumbSegment">
                      <StackPanel Orientation="Horizontal">
                        <Button Classes="crumb" Content="{Binding Name}"
                                Command="{Binding $parent[ItemsControl].((vm:LocalFilePaneViewModel)DataContext).NavigateToCommand}"
                                CommandParameter="{Binding Path}" />
                <TextBlock Text="{Binding $parent[ItemsControl].((vm:LocalFilePaneViewModel)DataContext).PathSeparator}"
                           Foreground="{DynamicResource VelaTextMuted}"
                           FontFamily="{DynamicResource VelaTerminalFont}"
                           FontSize="11" VerticalAlignment="Center" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
            <ProgressBar Width="54" Height="3" Margin="12,0"
                         HorizontalAlignment="Left" IsIndeterminate="True"
                         VerticalAlignment="Center"
                         IsVisible="{Binding IsDirectoryLoading}" />
          </Grid>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <ComboBox MinHeight="0" Height="22" Padding="6,0" FontSize="11"
                      ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot, Mode=OneWay}"
                      SelectionChanged="OnRootSelectionChanged"
                      VerticalContentAlignment="Center" MaxDropDownHeight="320">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LocalRootEntry">
                  <TextBlock Text="{Binding DisplayName}" ToolTip.Tip="{Binding Tooltip}"
                             TextTrimming="CharacterEllipsis" FontSize="11" Padding="2,1" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    Command="{Binding GoUpCommand}">
              <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.corner-left-up}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    Command="{Binding RefreshCommand}" ToolTip.Tip="{x:Static res:Strings.Refresh}">
              <pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.refresh-cw}"
                             Foreground="{DynamicResource VelaTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>
      <Border DockPanel.Dock="Top" Height="26" Padding="14,0"
              Background="{DynamicResource VelaBgSurface}"
              BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,90,130">
          <TextBlock Text="{x:Static res:Strings.FileName}" FontFamily="{DynamicResource VelaTerminalFont}"
                     FontSize="10" LetterSpacing="1" Foreground="{DynamicResource VelaTextMuted}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Size}" FontFamily="{DynamicResource VelaTerminalFont}"
                     FontSize="10" LetterSpacing="1" Foreground="{DynamicResource VelaTextMuted}"
                     VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{x:Static res:Strings.Modified}" FontFamily="{DynamicResource VelaTerminalFont}"
                     FontSize="10" LetterSpacing="1" Foreground="{DynamicResource VelaTextMuted}"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>
      <Border DockPanel.Dock="Top" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="{DynamicResource VelaBgActive}" Padding="8,4">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource VelaAccent}" FontSize="11" />
      </Border>
      <ListBox x:Name="FileList" ItemsSource="{Binding Entries}" SelectedItems="{Binding SelectedEntries}"
               SelectionMode="Multiple" Background="Transparent" BorderThickness="0"
               DoubleTapped="OnFileDoubleTapped">
        <ListBox.ContextMenu>
          <ContextMenu x:DataType="vm:LocalFilePaneViewModel">
            <MenuItem Header="{x:Static res:Strings.Refresh}" Command="{Binding RefreshCommand}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.refresh-cw}" Foreground="{DynamicResource VelaTextTertiary}" /></MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="{loc:Localize Sftp_Open}" Command="{Binding OpenItemCommand}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.file-text}" Foreground="{DynamicResource VelaAccent}" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{x:Static res:Strings.Upload}" Command="{Binding UploadSelectedCommand}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.upload}" Foreground="{DynamicResource VelaAccent}" /></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{x:Static res:Strings.Rename}" Command="{Binding RenameCommand}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.pencil}" Foreground="{DynamicResource VelaTextTertiary}" /></MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="{x:Static res:Strings.NewFolder}" Command="{Binding NewFolderCommand}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.folder-plus}" Foreground="{DynamicResource VelaTextTertiary}" /></MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="{x:Static res:Strings.Delete}" Command="{Binding DeleteSelectedCommand}" Foreground="{DynamicResource VelaError}">
              <MenuItem.Icon><pc:LucideIcon Width="13" Height="13" Data="{StaticResource Icon.trash-2}" Foreground="{DynamicResource VelaError}" /></MenuItem.Icon>
            </MenuItem>
          </ContextMenu>
        </ListBox.ContextMenu>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:LocalFileEntry">
            <Border Classes="file-row" Classes.parent="{Binding IsParentEntry}" Height="28" Padding="14,0"
                    BorderBrush="{DynamicResource VelaBorderPrimary}" BorderThickness="0,0,0,1"
                    PointerPressed="OnFileRowPointerPressed">
              <Grid ColumnDefinitions="*,90,130">
                <Grid Classes="local-name-cell" ColumnDefinitions="Auto,*" MinWidth="0"
                      ClipToBounds="True" VerticalAlignment="Center">
                  <pc:LucideIcon Width="13" Height="13" Margin="0,0,7,0"
                                 Data="{StaticResource Icon.folder}" Foreground="{DynamicResource VelaFileFolderIcon}"
                                 IsVisible="{Binding IsRegularDirectory}" />
                  <pc:LucideIcon Width="13" Height="13" Margin="0,0,7,0"
                                 Data="{StaticResource Icon.file}" Foreground="{DynamicResource VelaTextTertiary}"
                                 IsVisible="{Binding IsRegularFile}" />
                  <pc:LucideIcon Width="13" Height="13" Margin="0,0,7,0"
                                 Data="{StaticResource Icon.corner-left-up}" Foreground="{DynamicResource VelaTextTertiary}"
                                 IsVisible="{Binding IsParentEntry}" />
                  <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontFamily="{DynamicResource VelaTerminalFont}"
                             FontSize="11" Foreground="{DynamicResource VelaTextSecondary}"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </Grid>
                <TextBlock Classes="local-size-cell" Grid.Column="1" Text="{Binding FormattedSize}" FontFamily="{DynamicResource VelaTerminalFont}"
                           FontSize="11" Foreground="{DynamicResource VelaTextTertiary}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding FormattedModifiedTime}" FontFamily="{DynamicResource VelaTerminalFont}"
                           FontSize="11" Foreground="{DynamicResource VelaTextTertiary}" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </Border>
</UserControl>
