<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:models="using:VelaShell.Core.Models"
             xmlns:loc="using:VelaShell.Localization"
             x:Class="VelaShell.Views.Settings.SecurityAuditPage"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="14">
    <StackPanel Spacing="2">
      <TextBlock Classes="page-title" Text="{loc:Localize SetSecurity_Title}" />
      <TextBlock Classes="page-subtitle" Text="{loc:Localize SetSecurity_Subtitle}" />
    </StackPanel>

    <!-- 会话录制(设计 NceE6;设置审计 R-11 已实现恢复展示)。
         输入脱敏(R-12)不再需要:录制仅捕获终端输出流,密码输入本就无回显。 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetSecurity_SectionRecording}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_AutoRecord}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_AutoRecordDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.RecordProductionSessions}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_RecordingCenter}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_RecordingCenterDesc}" />
      </StackPanel>
      <Button Grid.Column="1" Classes="dlg-outline" Content="{loc:Localize SetSecurity_OpenPlayer}"
              Click="OpenRecordingPlayer_Click" VerticalAlignment="Center" />
    </Grid>

    <Border Classes="sep" />

    <!-- 主机信任策略 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetSecurity_SectionTrust}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_ConfirmFirstFingerprint}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_ConfirmFirstFingerprintDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.ConfirmFirstFingerprint}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_BlockOnChange}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_BlockOnChangeDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.BlockOnFingerprintChange}" VerticalAlignment="Center" />
    </Grid>

    <Border Classes="sep" />

    <!-- 已信任主机(known_hosts):查看/删除已记录的主机指纹。
         删除即时生效,下次连接该主机将重新执行首次指纹确认流程。 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetSecurity_SectionKnownHosts}" />
    <TextBlock Classes="row-desc"
               Text="{loc:Localize SetSecurity_KnownHostsDesc}" />
    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasKnownHosts}">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_MaskAddresses}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_MaskAddressesDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding MaskKnownHostAddresses}" VerticalAlignment="Center" />
    </Grid>
    <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_NoKnownHosts}"
               IsVisible="{Binding !HasKnownHosts}" />
    <Border Classes="table" IsVisible="{Binding HasKnownHosts}">
      <ItemsControl ItemsSource="{Binding KnownHosts}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:KnownHost">
            <Border Padding="12,8"
                    BorderBrush="{DynamicResource VelaBorderPrimary}"
                    BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- 地址脱敏:掩码为固定长度,不暴露真实地址的位数;
                         按指纹区分各条目(指纹是服务器公钥哈希,非敏感信息)。 -->
                    <TextBlock FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource VelaTextPrimary}"
                               IsVisible="{Binding !$parent[ItemsControl].((vm:SettingsViewModel)DataContext).MaskKnownHostAddresses}">
                      <Run Text="{Binding Host}" /><Run Text=":" /><Run Text="{Binding Port}" />
                    </TextBlock>
                    <TextBlock FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource VelaTextPrimary}"
                               Text="••••••••••:•••"
                               IsVisible="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).MaskKnownHostAddresses}" />
                    <TextBlock FontSize="10" VerticalAlignment="Center"
                               Foreground="{DynamicResource VelaTextMuted}"
                               Text="{Binding KeyType}" />
                  </StackPanel>
                  <TextBlock FontSize="10"
                             FontFamily="{DynamicResource VelaTerminalFont}"
                             Foreground="{DynamicResource VelaTextMuted}"
                             TextWrapping="Wrap"
                             Text="{Binding Fingerprint}" />
                </StackPanel>
                <Button Grid.Column="1" Classes="dlg-danger" Content="{loc:Localize Delete}"
                        VerticalAlignment="Center"
                        Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveKnownHostCommand}"
                        CommandParameter="{Binding}" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <Border Classes="sep" />

    <!-- 告警通道 -->
    <TextBlock Text="{loc:Localize SetSecurity_SectionAlerts}"
               Foreground="#74B9FF" FontSize="12" FontWeight="SemiBold" />
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_AlertInApp}" VerticalAlignment="Center" />
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.AlertInApp}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSecurity_AlertSound}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_AlertSoundDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.AlertSound}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="Webhook" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSecurity_WebhookDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding Security.AlertWebhook}" VerticalAlignment="Center" />
    </Grid>
    <!-- 从属设置:开启 Webhook 后显示(设置审计 §10)。 -->
    <StackPanel Spacing="5" IsVisible="{Binding Security.AlertWebhook}">
      <TextBlock Classes="row-label" Text="Webhook URL" />
      <TextBox Text="{Binding Security.WebhookUrl}" PlaceholderText="https://example.com/hooks/velashell" />
      <TextBlock Classes="row-desc"
                 Text="{loc:Localize SetSecurity_WebhookPayloadDesc}" />
    </StackPanel>
  </StackPanel>
</UserControl>
