<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:pvm="using:VelaShell.Presentation.ViewModels"
             xmlns:loc="using:VelaShell.Localization"
             x:Class="VelaShell.Views.Settings.SnippetsPage"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="14">
    <StackPanel Spacing="2">
      <TextBlock Classes="page-title" Text="{loc:Localize SetSnippets_Title}" />
      <TextBlock Classes="page-subtitle" Text="{loc:Localize SetSnippets_Subtitle}" />
    </StackPanel>

    <TextBlock Text="{loc:Localize SetSnippets_Intro}"
               Foreground="{DynamicResource VelaTextSecondary}"
               FontSize="13" TextWrapping="Wrap" />

    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetSnippets_ShowInSidebar}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetSnippets_ShowInSidebarDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1"
                    IsChecked="{Binding Appearance.ShowQuickCommandsPanel}"
                    VerticalAlignment="Center" />
    </Grid>

    <TextBlock Text="{Binding Snippets.ErrorMessage}"
               Foreground="{DynamicResource VelaStatusError}"
               TextWrapping="Wrap"
               IsVisible="{Binding Snippets.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    <ItemsControl ItemsSource="{Binding Snippets.FilteredGroups}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="pvm:QuickCommandGroupViewModel">
          <Border Margin="0,0,0,8" CornerRadius="6"
                  BorderBrush="{DynamicResource VelaBorderSecondary}"
                  BorderThickness="1">
            <StackPanel>
              <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                            Background="{DynamicResource VelaBgSurface}"
                            BorderThickness="0" Padding="12,8"
                            HorizontalContentAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1" Text="{Binding FilteredCommands.Count}"
                             Foreground="{DynamicResource VelaTextMuted}" FontSize="10" />
                </Grid>
              </ToggleButton>

              <ItemsControl ItemsSource="{Binding FilteredCommands}"
                            IsVisible="{Binding IsExpanded}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="pvm:QuickCommandViewModel">
                    <Border Padding="12,8" BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource VelaBorderSecondary}">
                      <Grid ColumnDefinitions="*,12,Auto,6,Auto">
                        <StackPanel Spacing="3">
                          <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium" />
                          <TextBlock Text="{Binding CommandText}"
                                     Foreground="{DynamicResource VelaAccentText}"
                                     FontFamily="{DynamicResource VelaTerminalFont}"
                                     FontSize="10" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="2" Height="24" Padding="8,0"
                                Content="{loc:Localize Edit}"
                                IsVisible="{Binding !IsBuiltIn}"
                                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.BeginEditCommand}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="4" Height="24" Padding="8,0"
                                Content="{loc:Localize Delete}"
                                IsVisible="{Binding !IsBuiltIn}"
                                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.DeleteCommandCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Classes="sep" />

    <StackPanel Spacing="10" DataContext="{Binding Snippets.EditingCommand}"
                IsVisible="{Binding Converter={x:Static ObjectConverters.IsNotNull}}">
      <TextBlock Classes="section-title" Text="{loc:Localize QuickCmd_EditSnippet}" />
      <Grid ColumnDefinitions="*,8,*">
        <TextBox Text="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.NewName}"
                 PlaceholderText="{loc:Localize SetSnippets_NamePlaceholder}" />
        <ComboBox Grid.Column="2" IsEditable="True"
                  ItemsSource="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.Categories}"
                  Text="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.NewCategory}"
                  PlaceholderText="{loc:Localize QuickCmd_GroupPlaceholder}" />
      </Grid>
      <TextBox Text="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.NewCommandText}"
               PlaceholderText="{loc:Localize SetSnippets_CommandPlaceholder}" />
      <TextBox Text="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.NewDescription}"
               PlaceholderText="{loc:Localize Description}" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Classes="dlg-secondary" Content="{loc:Localize Cancel}"
                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.CancelEditCommand}" />
        <Button Classes="dlg-primary" Content="{loc:Localize Save}"
                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).Snippets.SaveEditCommand}" />
      </StackPanel>
    </StackPanel>

    <TextBlock Classes="section-title" Text="{loc:Localize SetSnippets_NewSnippet}" />
    <Grid ColumnDefinitions="*,8,*">
      <TextBox Text="{Binding Snippets.NewName}"
               PlaceholderText="{loc:Localize SetSnippets_NamePlaceholder}" />
      <ComboBox Grid.Column="2" IsEditable="True"
                ItemsSource="{Binding Snippets.Categories}"
                Text="{Binding Snippets.NewCategory}"
                PlaceholderText="{loc:Localize QuickCmd_GroupPlaceholder}" />
    </Grid>
    <TextBox Text="{Binding Snippets.NewCommandText}"
             PlaceholderText="{loc:Localize SetSnippets_CommandPlaceholder}" />
    <TextBox Text="{Binding Snippets.NewDescription}"
             PlaceholderText="{loc:Localize Description}" />
    <Button Classes="dlg-primary" HorizontalAlignment="Right"
            Content="{loc:Localize SetSnippets_Add}"
            Command="{Binding Snippets.SaveNewCommandCommand}" />
  </StackPanel>
</UserControl>
