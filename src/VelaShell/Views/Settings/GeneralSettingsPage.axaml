<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VelaShell.ViewModels"
             xmlns:loc="using:VelaShell.Localization"
             x:Class="VelaShell.Views.Settings.GeneralSettingsPage"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="14">
    <StackPanel Spacing="2">
      <TextBlock Classes="page-title" Text="{loc:Localize SetGeneral_Title}" />
      <TextBlock Classes="page-subtitle" Text="{loc:Localize SetGeneral_Subtitle}" />
    </StackPanel>

    <!-- 启动与窗口 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_StartupSection}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_LaunchAtStartup}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_LaunchAtStartupDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.LaunchAtStartup}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_RestoreSessions}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_RestoreSessionsDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.RestoreSessionsOnStartup}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_MinimizeToTray}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_MinimizeToTrayDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.MinimizeToTray}" VerticalAlignment="Center" />
    </Grid>
    <!-- 启动时检查更新 / 更新频道 / 自动下载:更新服务尚未接入,暂不展示(设置审计 R-01~R-03);
         字段仍持久化,功能实现后恢复展示。 -->

    <Border Classes="sep" />

    <!-- 语言与区域 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_LanguageSection}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize Language}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_UiLanguageDesc}" />
      </StackPanel>
      <!-- 条目顺序必须与 SettingsViewModel.AvailableLanguages 一致;
           语言名用各语言本名(任何界面语言下都能认出自己的语言)。 -->
      <ComboBox Grid.Column="1" Width="160" SelectedIndex="{Binding LanguageIndex}" VerticalAlignment="Center">
        <ComboBoxItem Content="简体中文" />
        <ComboBoxItem Content="English" />
        <ComboBoxItem Content="繁體中文" />
        <ComboBoxItem Content="日本語" />
        <ComboBoxItem Content="한국어" />
      </ComboBox>
    </Grid>

    <Border Classes="sep" />

    <!-- 连接默认值 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_ConnectionDefaultsSection}" />
    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">
      <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
        <TextBlock Classes="row-label" FontSize="11" Text="{loc:Localize DefaultPort}" />
        <NumericUpDown Width="NaN" HorizontalAlignment="Stretch" Value="{Binding DefaultPort}" Minimum="1" Maximum="65535" Increment="1" FormatString="0" />
      </StackPanel>
      <StackPanel Grid.Row="0" Grid.Column="2" Spacing="5">
        <TextBlock Classes="row-label" FontSize="11" Text="{loc:Localize SetGeneral_ConnectTimeout}" />
        <NumericUpDown Width="NaN" HorizontalAlignment="Stretch" Value="{Binding General.ConnectTimeoutSeconds}" Minimum="1" Maximum="600" Increment="5" FormatString="0" />
      </StackPanel>
      <StackPanel Grid.Row="2" Grid.Column="0" Spacing="5">
        <TextBlock Classes="row-label" FontSize="11" Text="{loc:Localize SetGeneral_KeepAliveInterval}" />
        <NumericUpDown Width="NaN" HorizontalAlignment="Stretch" Value="{Binding General.KeepAliveSeconds}" Minimum="0" Maximum="600" Increment="10" FormatString="0" />
      </StackPanel>
    </Grid>

    <Border Classes="sep" />

    <!-- 数据与存储 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_DataSection}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_SessionLogging}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_SessionLoggingDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.SessionLogging}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding General.SessionLogging}">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_LogRetentionDays}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_LogRetentionDaysDesc}" />
      </StackPanel>
      <NumericUpDown Grid.Column="1" Width="80" Value="{Binding General.LogRetentionDays}" Minimum="1" Maximum="365" Increment="1" FormatString="0" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_ImportExport}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_ImportExportDesc}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <Button Classes="dlg-outline" Content="{loc:Localize SetGeneral_Export}" Click="ExportSettings_Click" />
        <Button Classes="dlg-outline" Content="{loc:Localize SetGeneral_Import}" Click="ImportSettings_Click" />
      </StackPanel>
    </Grid>

    <Border Classes="sep" />

    <!-- 行为 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_BehaviorSection}" />
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_ConfirmBeforeClose}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_ConfirmBeforeCloseDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.ConfirmBeforeClose}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_FollowActiveTerminal}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_FollowActiveTerminalDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1"
                    IsChecked="{Binding General.FollowActiveTerminalInExplorer}"
                    VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_NotifyOnDisconnect}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_NotifyOnDisconnectDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.NotifyOnDisconnect}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_SoundOnDisconnect}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_SoundOnDisconnectDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.SoundAlerts}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_AutoReconnect}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_AutoReconnectDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.AutoReconnect}" VerticalAlignment="Center" />
    </Grid>
    <!-- 自动重连的从属设置:父项关闭时隐藏,已保存值保留(设置审计 §10)。 -->
    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding General.AutoReconnect}">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_MaxRetries}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_MaxRetriesDesc}" />
      </StackPanel>
      <NumericUpDown Grid.Column="1" Width="80" Value="{Binding General.MaxRetries}" Minimum="1" Maximum="20" Increment="1" FormatString="0" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding General.AutoReconnect}">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_ReconnectInterval}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_ReconnectIntervalDesc}" />
      </StackPanel>
      <NumericUpDown Grid.Column="1" Width="80" Value="{Binding General.ReconnectIntervalSeconds}" Minimum="1" Maximum="300" Increment="1" FormatString="0" VerticalAlignment="Center" />
    </Grid>

    <Border Classes="sep" />

    <!-- 隐私与安全 -->
    <TextBlock Classes="section-title" Text="{loc:Localize SetGeneral_PrivacySection}" />
    <!-- 主密码保护:密钥派生/解锁/凭据迁移未实现,暂不展示(设置审计 R-04);
         当前凭据已用本机密钥(AES)加密存储。 -->
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_RememberPasswords}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_RememberPasswordsDesc}" />
      </StackPanel>
      <ToggleSwitch Grid.Column="1" IsChecked="{Binding General.RememberPasswords}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="2">
        <TextBlock Classes="row-label" Text="{loc:Localize SetGeneral_ClearHistory}" />
        <TextBlock Classes="row-desc" Text="{loc:Localize SetGeneral_ClearHistoryDesc}" />
      </StackPanel>
      <!-- 破坏性操作:点击后先弹确认框(代码后置),确认才执行(设置审计 §12)。 -->
      <Button Grid.Column="1" Classes="dlg-danger" Content="{loc:Localize SetGeneral_Clear}"
              Click="ClearHistory_Click" VerticalAlignment="Center" />
    </Grid>
    <TextBlock Classes="row-desc"
               Text="{Binding ClearHistoryStatus}"
               IsVisible="{Binding ClearHistoryStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
