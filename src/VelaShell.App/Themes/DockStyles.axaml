<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dc="using:Dock.Avalonia.Controls"
        xmlns:docking="using:VelaShell.App.Docking"
        xmlns:conv="using:VelaShell.App.Converters"
        xmlns:pc="using:VelaShell.Controls.Controls"
        xmlns:views="using:VelaShell.App.Views">

    <!-- Re-skin the Dock.Avalonia document tab strip to match design frame nunbT exactly:
         36px bg-page bar; 32px tabs padding [0,14]; active = tab-active bg + 2px accent top
         line + JB Mono 11 medium text-primary; inactive = tab-inactive bg + text-tertiary;
         status dot 7px + close x 12px, gap 8. -->

    <Style Selector="dc|DockControl">
        <Setter Property="Background" Value="{DynamicResource PulseBgPage}" />
    </Style>

    <Style Selector="dc|DocumentControl">
        <Setter Property="Background" Value="{DynamicResource PulseBgTerminal}" />
    </Style>

    <!-- No border around the document content area — the terminal fills its pane edge to
         edge (nunbT). -->
    <Style Selector="dc|DocumentControl /template/ Border#PART_Border">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- The 1px line under the tab strip is a plain themed divider (用户要求): same brush
         whether or not the pane has focus — no click feedback, no Fluent-blue active state. -->
    <Style Selector="dc|DocumentControl /template/ Panel#PART_DocumentSeperator">
        <Setter Property="Background" Value="{DynamicResource PulseBorderPrimary}" />
    </Style>
    <Style Selector="dc|DocumentControl:active /template/ Panel#PART_DocumentSeperator">
        <Setter Property="Background" Value="{DynamicResource PulseBorderPrimary}" />
    </Style>

    <!-- 35px strip + the 1px separator below = 36px total, so the divider lands on the same
         horizontal line as the sidebar header's bottom border (which is drawn INSIDE its
         36px row) — they used to sit 1px apart (用户反馈). -->
    <Style Selector="dc|DocumentTabStrip">
        <Setter Property="Background" Value="{DynamicResource PulseBgPage}" />
        <Setter Property="MinHeight" Value="35" />
    </Style>

    <!-- The tab templates MUST be set on DocumentControl, not on the strip: the control's
         template forwards them to the strip via TemplateBinding (a local value), so setters
         aimed at the strip never applied — which is why the default Dock close glyph kept
         showing no matter what the strip style said. -->
    <Style Selector="dc|DocumentControl">
        <!-- Status dot (7px) in front of the title, colored by the session state. Nudged up
             1px: the mono title's descender pulls its visual center above the geometric one,
             so a dead-center dot reads as sitting low (用户反馈). -->
        <Setter Property="IconTemplate">
            <DataTemplate x:DataType="docking:TerminalDocument">
                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                         Fill="{Binding Terminal.ConnectionStatus, Converter={x:Static conv:SessionStatusToBrushConverter.Instance}}">
                    <Ellipse.RenderTransform>
                        <TranslateTransform Y="-1" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </DataTemplate>
        </Setter>
        <!-- Tab title. Hovering the NAME for >400ms floats the session's resource panel at the
             pointer; leaving hides it (§4B.4/§11 — the spec anchors hover on the tab name). -->
        <Setter Property="HeaderTemplate">
            <DataTemplate x:DataType="docking:TerminalDocument">
                <TextBlock Text="{Binding Title}"
                           VerticalAlignment="Center"
                           ToolTip.ShowDelay="400"
                           ToolTip.Placement="Pointer">
                    <ToolTip.Tip>
                        <views:ResourceMonitorView DataContext="{Binding Terminal.ResourceMonitor}" />
                    </ToolTip.Tip>
                </TextBlock>
            </DataTemplate>
        </Setter>
        <!-- Close x: 11px lucide x, sized to sit quietly beside the 11px tab title. -->
        <Setter Property="CloseTemplate">
            <DataTemplate x:DataType="docking:TerminalDocument">
                <Button Background="Transparent" Padding="0" Width="14" Height="14"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Command="{Binding Owner.Factory.CloseDockable}"
                        CommandParameter="{Binding}">
                    <pc:LucideIcon Width="11" Height="11"
                                   Data="{StaticResource Icon.x}"
                                   Foreground="{DynamicResource PulseTextTertiary}" />
                </Button>
            </DataTemplate>
        </Setter>
    </Style>

    <!-- Tabs stretch to the full strip height so no bg-page sliver shows between the menu
         bar's divider and the tab tops (用户反馈：标签与菜单分割线之间的空隙). -->
    <Style Selector="dc|DocumentTabStripItem">
        <Setter Property="Background" Value="{DynamicResource PulseTabInactiveBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PulseTextTertiary}" />
        <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,2,0,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- Single-line inputs center their text vertically (设计稿所有输入框文本均为垂直居中);
         the Fluent default leaves the presenter top-aligned, which reads as the text floating
         high whenever the box is taller than one line (worst in the settings panel's 30px
         NumericUpDown fields). Multi-line boxes keep top alignment. -->
    <Style Selector="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox[AcceptsReturn=True]">
        <Setter Property="VerticalContentAlignment" Value="Top" />
    </Style>
    <Style Selector="NumericUpDown">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ToggleButton">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Token-styled tooltips (small-flyout spec: bg-surface + border-secondary + corner 6). -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{DynamicResource PulseBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Context menus (design 会话右键菜单 style): one look for every right-click menu — the
         session tree, the SFTP list, and the dock tab strip. Same small-flyout tokens as the
         tooltip (bg-surface + border-secondary + corner 6), JB Mono 11, compact rows. -->
    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource PulseBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Hover/selected highlight uses the shared bg-hover token instead of the Fluent accent fill. -->
    <Style Selector="ContextMenu MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector="ContextMenu MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector="ContextMenu MenuItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
    </Style>

    <!-- Disabled items (e.g. the forced-off MDI layout mode) read as muted, not hidden. -->
    <Style Selector="ContextMenu MenuItem:disabled">
        <Setter Property="Foreground" Value="{DynamicResource PulseTextMuted}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Background" Value="{DynamicResource PulseBorderPrimary}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,4" />
    </Style>

    <!-- Tab-strip overflow controls (design nunbT pZGS4): 24px, corner 3, hover bg-hover.
         Base metrics live here so the DockTabStrip.axaml template stays minimal. -->
    <Style Selector=":is(Button).tab-nav">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector=":is(Button).tab-nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector=":is(Button).tab-nav:disabled">
        <Setter Property="Opacity" Value="0.35" />
    </Style>

    <!-- Tab-list dropdown (and any MenuFlyout): same small-flyout look as the context menus. -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource PulseBgSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector="MenuFlyoutPresenter MenuItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
    </Style>
    <!-- 下拉里当前激活的标签:accent + 加粗(DockTabStripResources 挂 active-tab 类)。 -->
    <Style Selector="MenuFlyoutPresenter MenuItem.active-tab">
        <Setter Property="Foreground" Value="{DynamicResource PulseAccent}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="dc|DocumentTabStripItem:pointerover:not(:selected):not(:dragging)">
        <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
        <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
    </Style>

    <Style Selector="dc|DocumentTabStripItem:selected">
        <Setter Property="Background" Value="{DynamicResource PulseTabActiveBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PulseAccent}" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>

</Styles>
