<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <!-- Dracula 暗色(用户确认):accent=紫 #BD93F9,弱文字取官方 comment #6272A4,
         边框用 #44475A(selection)家族。 -->
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="PulseAccent" Color="#BD93F9" />
      <SolidColorBrush x:Key="PulseAccentDim" Color="#BD93F930" />
      <SolidColorBrush x:Key="PulseTextPrimary" Color="#F8F8F2" />
      <SolidColorBrush x:Key="PulseTextSecondary" Color="#B0B8D6" />
      <SolidColorBrush x:Key="PulseTextTertiary" Color="#6272A4" />
      <SolidColorBrush x:Key="PulseTextMuted" Color="#545B76" />
      <SolidColorBrush x:Key="PulseBorderPrimary" Color="#3B3E51" />
      <SolidColorBrush x:Key="PulseBorderSecondary" Color="#44475A" />
      <SolidColorBrush x:Key="PulseStatusConnected" Color="#50FA7B" />
      <SolidColorBrush x:Key="PulseStatusConnecting" Color="#F1FA8C" />
      <SolidColorBrush x:Key="PulseStatusDisconnected" Color="#FF5555" />
      <!-- File browser rows (design frame dyuii): orange folder icon, cyan directory names. -->
      <SolidColorBrush x:Key="PulseFileFolderIcon" Color="#FFB86C" />
      <SolidColorBrush x:Key="PulseFileDirName" Color="#8BE9FD" />
      <FontFamily x:Key="PulseTerminalFont">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>
      <FontFamily x:Key="PulseUiFont">fonts:Inter#Inter, Segoe UI, Microsoft YaHei, sans-serif</FontFamily>
    </ResourceDictionary>
    <!-- Alucard 亮色(用户确认):accent=紫 #644AC9,弱文字取 Alucard comment #6C664B。 -->
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="PulseAccent" Color="#644AC9" />
      <SolidColorBrush x:Key="PulseAccentDim" Color="#644AC91A" />
      <SolidColorBrush x:Key="PulseTextPrimary" Color="#1F1F1F" />
      <SolidColorBrush x:Key="PulseTextSecondary" Color="#4A4636" />
      <SolidColorBrush x:Key="PulseTextTertiary" Color="#6C664B" />
      <SolidColorBrush x:Key="PulseTextMuted" Color="#9A9377" />
      <SolidColorBrush x:Key="PulseBorderPrimary" Color="#E3DCBF" />
      <SolidColorBrush x:Key="PulseBorderSecondary" Color="#D3CBA9" />
      <SolidColorBrush x:Key="PulseStatusConnected" Color="#14710A" />
      <SolidColorBrush x:Key="PulseStatusConnecting" Color="#846E15" />
      <SolidColorBrush x:Key="PulseStatusDisconnected" Color="#CB3A2A" />
      <!-- File browser rows: Alucard yellow folders, cyan directory names. -->
      <SolidColorBrush x:Key="PulseFileFolderIcon" Color="#9E841A" />
      <SolidColorBrush x:Key="PulseFileDirName" Color="#036A96" />
      <FontFamily x:Key="PulseTerminalFont">JetBrains Mono, Cascadia Mono, Consolas, monospace</FontFamily>
      <FontFamily x:Key="PulseUiFont">fonts:Inter#Inter, Segoe UI, Microsoft YaHei, sans-serif</FontFamily>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
