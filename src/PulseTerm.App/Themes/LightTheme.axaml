<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- PulseTerm Light Theme — Derived from dark tokens for light backgrounds -->

    <!-- Accent tokens (adjusted for light background contrast) -->
    <SolidColorBrush x:Key="PulseAccentText" Color="#008568" />

    <!-- Semantic tokens -->
    <SolidColorBrush x:Key="PulseWarning" Color="#BF8700" />
    <SolidColorBrush x:Key="PulseError" Color="#CF222E" />
    <SolidColorBrush x:Key="PulseInfo" Color="#0969DA" />

</ResourceDictionary>
