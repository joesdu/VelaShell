<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dockFluent="using:Dock.Avalonia.Themes.Fluent"
             x:Class="PulseTerm.App.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <dockFluent:DockFluentTheme />
        <StyleInclude Source="avares://PulseTerm.App/Themes/DockStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PulseTerm.Controls/Themes/Generic.axaml" />
                <ResourceInclude Source="avares://PulseTerm.Controls/Themes/PulseTokens.axaml" />
                <ResourceInclude Source="avares://PulseTerm.Controls/Themes/PulseShellTokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/DarkTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="/Themes/LightTheme.axaml" />
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
