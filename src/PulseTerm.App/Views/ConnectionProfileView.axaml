<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PulseTerm.App.ViewModels"
        xmlns:behaviors="using:PulseTerm.App.Behaviors"
        xmlns:models="clr-namespace:PulseTerm.Core.Models;assembly=PulseTerm.Core"
        mc:Ignorable="d" d:DesignWidth="500"
        x:Class="PulseTerm.App.Views.ConnectionProfileView"
        x:DataType="vm:ConnectionProfileViewModel"
        Title="新建连接"
        Width="500"
        SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <!-- 表单标签 -->
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Margin" Value="0,0,0,5" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
    </Style>
    <!-- 底部按钮:描边(测试/保存)与主色(连接) -->
    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-primary">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <!-- 协议标签页 -->
    <Style Selector="Border.proto-tab">
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
    </Style>
    <Style Selector="TextBlock.proto-label">
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <!-- 自绘对话框卡片(设计:圆角 8、外描边、投影) -->
  <Border CornerRadius="8"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12">
    <StackPanel>

      <!-- Header: plug 图标 + 标题 + 关闭 -->
      <Border Height="48" Padding="20,0"
              PointerPressed="Header_PointerPressed"
              Background="Transparent"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource PulseBorderPrimary}">
        <Grid ColumnDefinitions="Auto,8,*,Auto">
          <PathIcon Grid.Column="0" Width="16" Height="16"
                    Data="M16 7V3h-2v4h-4V3H8v4c-1.1 0-2 .9-2 2v5.5L9.5 18v3h5v-3L18 14.5V9c0-1.1-.9-2-2-2z"
                    Foreground="{DynamicResource PulseAccent}"
                    VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="新建连接"
                     Foreground="{DynamicResource PulseTextPrimary}"
                     FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="3" Width="24" Height="24"
                  Background="Transparent" Padding="0" CornerRadius="3"
                  Cursor="Hand" Command="{Binding CancelCommand}">
            <PathIcon Width="14" Height="14"
                      Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- 协议标签页:SSH 激活;其余暂未支持 -->
      <Border Height="36" Padding="20,0"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource PulseBorderPrimary}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
          <Border Classes="proto-tab"
                  BorderThickness="0,0,0,2"
                  BorderBrush="{DynamicResource PulseAccent}">
            <TextBlock Classes="proto-label" Text="SSH"
                       Foreground="{DynamicResource PulseAccent}"
                       FontWeight="Medium" />
          </Border>
          <Border Classes="proto-tab" ToolTip.Tip="暂未支持">
            <TextBlock Classes="proto-label" Text="SFTP"
                       Foreground="{DynamicResource PulseTextTertiary}" />
          </Border>
          <Border Classes="proto-tab" ToolTip.Tip="暂未支持">
            <TextBlock Classes="proto-label" Text="Telnet"
                       Foreground="{DynamicResource PulseTextTertiary}" />
          </Border>
          <Border Classes="proto-tab" ToolTip.Tip="暂未支持">
            <TextBlock Classes="proto-label" Text="串口"
                       Foreground="{DynamicResource PulseTextTertiary}" />
          </Border>
        </StackPanel>
      </Border>

      <!-- 表单 -->
      <StackPanel Margin="20,18" Spacing="14">

        <!-- 主机名/IP + 端口 -->
        <Grid ColumnDefinitions="*,12,90">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="主机名 / IP" />
            <TextBox Text="{Binding Host}" PlaceholderText="192.168.1.100" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="端口" />
            <NumericUpDown Value="{Binding Port}" Minimum="1" Maximum="65535"
                           Increment="1" FormatString="0" ShowButtonSpinner="False" />
          </StackPanel>
        </Grid>

        <!-- 用户名 + 认证方式 -->
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="用户名" />
            <TextBox Text="{Binding Username}" PlaceholderText="root" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="认证方式" />
            <ComboBox SelectedIndex="{Binding AuthMethodIndex}">
              <ComboBoxItem Content="密码认证" />
              <ComboBoxItem Content="密钥认证" />
            </ComboBox>
          </StackPanel>
        </Grid>

        <!-- 密码(密码认证) -->
        <StackPanel IsVisible="{Binding IsPasswordAuth}">
          <TextBlock Classes="field-label" Text="密码" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding Password}"
                     behaviors:AsciiOnlyInput.IsEnabled="True"
                     PasswordChar="&#x2022;"
                     RevealPassword="{Binding ShowPassword}" />
            <Button Grid.Column="1" Width="28" Height="28"
                    Margin="-34,0,6,0" Padding="0"
                    Background="Transparent" CornerRadius="3" Cursor="Hand"
                    Command="{Binding TogglePasswordVisibilityCommand}"
                    ToolTip.Tip="显示/隐藏密码"
                    VerticalAlignment="Center" HorizontalAlignment="Right">
              <PathIcon Width="13" Height="13"
                        Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                        Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
          </Grid>
        </StackPanel>

        <!-- 私钥(密钥认证) -->
        <StackPanel IsVisible="{Binding IsKeyAuth}" Spacing="14">
          <StackPanel>
            <TextBlock Classes="field-label" Text="私钥文件" />
            <Grid ColumnDefinitions="*,8,Auto">
              <TextBox Grid.Column="0" Text="{Binding PrivateKeyPath}"
                       PlaceholderText="~/.ssh/id_ed25519" />
              <Button Grid.Column="2" Classes="dlg-outline"
                      Content="浏览…" Click="BrowseKeyFile_Click" />
            </Grid>
          </StackPanel>
          <StackPanel>
            <TextBlock Classes="field-label" Text="私钥口令(可选)" />
            <TextBox Text="{Binding PrivateKeyPassphrase}"
                     PasswordChar="&#x2022;" RevealPassword="False" />
          </StackPanel>
        </StackPanel>

        <!-- 记住密码 -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    IsVisible="{Binding IsPasswordAuth}">
          <CheckBox IsChecked="{Binding RememberPassword}"
                    Padding="0" MinHeight="0" VerticalAlignment="Center">
            <TextBlock Text="记住密码"
                       Foreground="{DynamicResource PulseTextSecondary}"
                       FontSize="11" FontWeight="Medium" />
          </CheckBox>
          <TextBlock Text="(将使用 AES-256 加密存储)"
                     Foreground="{DynamicResource PulseTextMuted}"
                     FontFamily="{DynamicResource PulseTerminalFont}"
                     FontSize="10"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- 会话分组 + 显示名称 -->
        <Grid ColumnDefinitions="*,12,*">
          <StackPanel Grid.Column="0">
            <TextBlock Classes="field-label" Text="会话分组" />
            <ComboBox ItemsSource="{Binding Groups}"
                      SelectedItem="{Binding SelectedGroup}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Classes="field-label" Text="显示名称" />
            <TextBox Text="{Binding Name}" PlaceholderText="web-prod-03" />
          </StackPanel>
        </Grid>

        <!-- 高级选项内容 -->
        <StackPanel IsVisible="{Binding IsAdvancedVisible}">
          <TextBlock Classes="field-label" Text="标签(逗号分隔)" />
          <TextBox Text="{Binding TagsText}" PlaceholderText="web, 生产" />
        </StackPanel>

        <!-- 测试/保存反馈 -->
        <TextBlock Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   Foreground="#FF6B6B" FontSize="11" TextWrapping="Wrap" />
        <TextBlock Text="连接测试成功"
                   IsVisible="{Binding ShowTestSuccess}"
                   Foreground="{DynamicResource PulseAccent}" FontSize="11" />
      </StackPanel>

      <!-- Footer -->
      <Border Height="52" Padding="20,0"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- 高级选项开关 -->
          <Button Grid.Column="0" Background="Transparent" Padding="0"
                  Cursor="Hand" Command="{Binding ToggleAdvancedCommand}"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Width="12" Height="12"
                        Data="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"
                        Foreground="{DynamicResource PulseTextTertiary}" />
              <TextBlock Text="高级选项"
                         Foreground="{DynamicResource PulseTextTertiary}"
                         FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <Button Classes="dlg-outline" Command="{Binding TestConnectionCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M11 21h-1l1-7H7.5c-.58 0-.57-.32-.38-.66.19-.34.05-.08.07-.12C8.48 10.94 10.42 7.54 13 3h1l-1 7h3.5c.49 0 .56.33.47.51l-.07.15C12.96 17.55 11 21 11 21z"
                          Foreground="{DynamicResource PulseTextSecondary}" />
                <TextBlock Text="测试" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="dlg-outline" Command="{Binding SaveCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                          Foreground="{DynamicResource PulseTextSecondary}" />
                <TextBlock Text="保存" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="dlg-primary" Command="{Binding ConnectCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M16 7V3h-2v4h-4V3H8v4c-1.1 0-2 .9-2 2v5.5L9.5 18v3h5v-3L18 14.5V9c0-1.1-.9-2-2-2z"
                          Foreground="#0A0E14" />
                <TextBlock Text="连接" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

    </StackPanel>
  </Border>
</Window>
