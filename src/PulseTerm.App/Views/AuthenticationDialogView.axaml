<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PulseTerm.App.ViewModels"
        xmlns:behaviors="using:PulseTerm.App.Behaviors"
        mc:Ignorable="d" d:DesignWidth="420"
        x:Class="PulseTerm.App.Views.AuthenticationDialogView"
        x:DataType="vm:AuthenticationDialogViewModel"
        Title="身份验证"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <Window.Styles>
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Margin" Value="0,0,0,5" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-primary">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="20,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <!-- 认证方式分段选择 -->
    <Style Selector="Button.seg-tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Height" Value="28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.seg-tab.active">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
  </Window.Styles>

  <Border CornerRadius="8"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12">
    <StackPanel>

      <!-- Header -->
      <Border Height="48" Padding="20,0"
              PointerPressed="Header_PointerPressed"
              Background="Transparent"
              BorderThickness="0,0,0,1"
              BorderBrush="{DynamicResource PulseBorderPrimary}">
        <Grid ColumnDefinitions="Auto,8,*,Auto">
          <PathIcon Grid.Column="0" Width="16" Height="16"
                    Data="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"
                    Foreground="{DynamicResource PulseAccent}"
                    VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{Binding HeaderTitle}"
                     Foreground="{DynamicResource PulseTextPrimary}"
                     FontSize="14" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="3" Width="24" Height="24"
                  Background="Transparent" Padding="0" CornerRadius="3"
                  Cursor="Hand" Command="{Binding CancelCommand}">
            <PathIcon Width="14" Height="14"
                      Data="M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- 信息栏:目标 + 指纹/用户名 -->
      <Border Background="{DynamicResource PulseBgInput}" Padding="20,12">
        <Grid ColumnDefinitions="Auto,10,*">
          <PathIcon Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center"
                    Foreground="{DynamicResource PulseAccent}"
                    Data="M4 1h16c1.1 0 2 .9 2 2v4c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2zm0 5h2v-2H4v2zm0 8h16c1.1 0 2 .9 2 2v4c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2v-4c0-1.1.9-2 2-2zm0 5h2v-2H4v2z" />
          <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
            <TextBlock Text="{Binding TargetText}"
                       Foreground="{DynamicResource PulseTextPrimary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="11" FontWeight="Medium" />
            <TextBlock Text="{Binding FingerprintText}"
                       IsVisible="{Binding IsStep1}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10" />
            <TextBlock Text="{Binding UsernameLine}"
                       IsVisible="{Binding IsStep2}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Body -->
      <StackPanel Margin="20,16" Spacing="14">

        <!-- 步骤指示器 -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <!-- 第 1 步圆点:数字或对勾 -->
          <Border Width="20" Height="20" CornerRadius="10"
                  Background="{DynamicResource PulseAccent}">
            <Panel>
              <TextBlock Text="1" IsVisible="{Binding IsStep1}"
                         Foreground="#0A0E14" FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
              <PathIcon Width="10" Height="10" IsVisible="{Binding IsStep2}"
                        Data="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"
                        Foreground="#0A0E14"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Panel>
          </Border>
          <!-- 连接线 -->
          <Border Width="40" Height="2" VerticalAlignment="Center"
                  Background="{DynamicResource PulseBorderSecondary}">
            <Border Background="{DynamicResource PulseAccent}"
                    IsVisible="{Binding IsStep2}" />
          </Border>
          <!-- 第 2 步圆点 -->
          <Border Width="20" Height="20" CornerRadius="10" Name="Step2Dot">
            <Border.Styles>
              <Style Selector="Border#Step2Dot">
                <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
                <Setter Property="BorderThickness" Value="1" />
              </Style>
            </Border.Styles>
            <Panel>
              <Border CornerRadius="10" Background="{DynamicResource PulseAccent}"
                      IsVisible="{Binding IsStep2}" Margin="-1" />
              <TextBlock Text="2" FontSize="10" FontWeight="SemiBold"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Styles>
                  <Style Selector="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource PulseTextMuted}" />
                  </Style>
                  <Style Selector="TextBlock.on-accent">
                    <Setter Property="Foreground" Value="#0A0E14" />
                  </Style>
                </TextBlock.Styles>
                <Classes.on-accent>
                  <Binding Path="IsStep2" />
                </Classes.on-accent>
              </TextBlock>
            </Panel>
          </Border>
          <TextBlock Text="输入用户名" IsVisible="{Binding IsStep1}"
                     Foreground="{DynamicResource PulseTextMuted}" FontSize="11"
                     VerticalAlignment="Center" />
          <TextBlock Text="选择认证方式" IsVisible="{Binding IsStep2}"
                     Foreground="{DynamicResource PulseTextMuted}" FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- 第 1 步:用户名 -->
        <StackPanel IsVisible="{Binding IsStep1}">
          <TextBlock Classes="field-label" Text="用户名" />
          <Grid ColumnDefinitions="Auto,*"
                Height="34">
            <Border Grid.ColumnSpan="2"
                    Background="{DynamicResource PulseBgInput}"
                    BorderBrush="{DynamicResource PulseBorderPrimary}"
                    BorderThickness="1" CornerRadius="4" />
            <PathIcon Grid.Column="0" Width="13" Height="13" Margin="12,0,0,0"
                      Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                      Foreground="{DynamicResource PulseTextTertiary}"
                      VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Text="{Binding Username}"
                     Background="Transparent" BorderThickness="0"
                     MinHeight="32" Margin="2,0,2,0"
                     PlaceholderText="root" />
          </Grid>
        </StackPanel>

        <!-- 第 2 步:认证方式 -->
        <StackPanel IsVisible="{Binding IsStep2}" Spacing="14">

          <!-- 分段选择:密码 / 证书 / 密钥 -->
          <Border Background="{DynamicResource PulseBgInput}" CornerRadius="4" Padding="2" Height="32">
            <Grid ColumnDefinitions="*,2,*,2,*">
              <Button Grid.Column="0" Classes="seg-tab" Content="密码"
                      Classes.active="{Binding IsPasswordMethod}"
                      Command="{Binding SelectPasswordCommand}" />
              <Button Grid.Column="2" Classes="seg-tab" Content="证书"
                      IsEnabled="False" ToolTip.Tip="暂未支持" />
              <Button Grid.Column="4" Classes="seg-tab" Content="密钥"
                      Classes.active="{Binding IsKeyMethod}"
                      Command="{Binding SelectKeyCommand}" />
            </Grid>
          </Border>

          <!-- 密码 -->
          <StackPanel IsVisible="{Binding IsPasswordMethod}" Spacing="14">
            <StackPanel>
              <TextBlock Classes="field-label" Text="密码" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Name="PasswordBox"
                         Text="{Binding Password}"
                         behaviors:AsciiOnlyInput.IsEnabled="True"
                         BorderBrush="{DynamicResource PulseAccent}"
                         PasswordChar="&#x2022;"
                         RevealPassword="{Binding ShowPassword}" />
                <Button Grid.Column="1" Width="28" Height="28"
                        Margin="-34,0,6,0" Padding="0"
                        Background="Transparent" CornerRadius="3" Cursor="Hand"
                        Command="{Binding TogglePasswordVisibilityCommand}"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                  <PathIcon Width="14" Height="14"
                            Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                            Foreground="{DynamicResource PulseTextMuted}" />
                </Button>
              </Grid>
            </StackPanel>

            <!-- 记住密码 + AES 徽标 -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <CheckBox IsChecked="{Binding RememberPassword}"
                          Padding="0" MinHeight="0" VerticalAlignment="Center">
                  <TextBlock Text="记住密码"
                             Foreground="{DynamicResource PulseTextSecondary}"
                             FontSize="11" />
                </CheckBox>
              </StackPanel>
              <Border Grid.Column="1" Background="{DynamicResource PulseAccentDim}"
                      CornerRadius="3" Padding="8,3" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <PathIcon Width="10" Height="10"
                            Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM9 8V6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9z"
                            Foreground="{DynamicResource PulseAccent}" />
                  <TextBlock Text="AES-256 加密存储"
                             Foreground="{DynamicResource PulseAccent}"
                             FontFamily="{DynamicResource PulseTerminalFont}"
                             FontSize="9" FontWeight="Medium"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>

          <!-- 密钥 -->
          <StackPanel IsVisible="{Binding IsKeyMethod}" Spacing="14">
            <StackPanel>
              <TextBlock Classes="field-label" Text="私钥文件" />
              <Grid ColumnDefinitions="*,8,Auto">
                <TextBox Grid.Column="0" Text="{Binding PrivateKeyPath}"
                         PlaceholderText="~/.ssh/id_ed25519" />
                <Button Grid.Column="2" Classes="dlg-outline"
                        Content="浏览…" Click="BrowseKeyFile_Click" />
              </Grid>
            </StackPanel>
            <StackPanel>
              <TextBlock Classes="field-label" Text="私钥口令(可选)" />
              <TextBox Text="{Binding PrivateKeyPassphrase}"
                       PasswordChar="&#x2022;" RevealPassword="False" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- Footer -->
      <Border Height="52" Padding="20,0"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- 第 2 步:上一步 -->
          <Button Grid.Column="0" Classes="dlg-outline"
                  IsVisible="{Binding IsStep2}"
                  Command="{Binding BackCommand}"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <PathIcon Width="12" Height="12"
                        Data="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                        Foreground="{DynamicResource PulseTextSecondary}" />
              <TextBlock Text="上一步" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <!-- 第 1 步:取消 / 下一步 -->
            <Button Classes="dlg-outline" Content="取消"
                    IsVisible="{Binding IsStep1}"
                    Command="{Binding CancelCommand}" />
            <Button Classes="dlg-primary"
                    IsVisible="{Binding IsStep1}"
                    Command="{Binding NextCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M4 11h12.17l-5.59-5.59L12 4l8 8-8 8-1.41-1.41L16.17 13H4v-2z"
                          Foreground="#0A0E14" />
                <TextBlock Text="下一步" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <!-- 第 2 步:登录 -->
            <Button Classes="dlg-primary"
                    IsVisible="{Binding IsStep2}"
                    Command="{Binding LoginCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Width="12" Height="12"
                          Data="M11 7 9.6 8.4l2.6 2.6H2v2h10.2l-2.6 2.6L11 17l5-5-5-5zm9 12h-8v2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-8v2h8v14z"
                          Foreground="#0A0E14" />
                <TextBlock Text="登录" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

    </StackPanel>
  </Border>
</Window>
