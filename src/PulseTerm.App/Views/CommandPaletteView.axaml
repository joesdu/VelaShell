<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="440"
             x:Class="PulseTerm.App.Views.CommandPaletteView"
             x:DataType="vm:CommandPaletteViewModel">

  <UserControl.Styles>
    <Style Selector="Border.pal-item">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Border.pal-item:pointerover">
      <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
    <Style Selector="Border.pal-item.selected">
      <Setter Property="Background" Value="{DynamicResource PulseBgActive}" />
    </Style>
    <Style Selector="TextBlock.cat">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextMuted}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Margin" Value="16,6,0,2" />
    </Style>
    <!-- 搜索框:与前置放大镜图标构成一个整体,清除 TextBox 在
         悬停/焦点态下自绘的不透明背景与边框,避免出现拼接的方框。 -->
    <Style Selector="TextBox#SearchBox /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox#SearchBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="TextBox#SearchBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
  </UserControl.Styles>

  <!-- 560px palette panel, matching the design frame FN5dM -->
  <Border Width="560"
          MaxHeight="460"
          VerticalAlignment="Top"
          Margin="0,120,0,0"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          CornerRadius="8"
          BoxShadow="0 8 32 0 #80000000">
    <DockPanel>

      <!-- Search bar -->
      <Border DockPanel.Dock="Top"
              Height="48"
              Padding="16,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <PathIcon Grid.Column="0"
                    Width="16" Height="16"
                    Margin="0,0,10,0"
                    Foreground="{DynamicResource PulseTextTertiary}"
                    Data="M15.5 14h-.79l-.28-.27a6.5 6.5 0 10-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0a4.5 4.5 0 110-9 4.5 4.5 0 010 9z" />
          <TextBox Grid.Column="1"
                   x:Name="SearchBox"
                   Text="{Binding Query}"
                   BorderThickness="0"
                   Background="Transparent"
                   Foreground="{DynamicResource PulseTextPrimary}"
                   CaretBrush="{DynamicResource PulseAccent}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="14"
                   VerticalContentAlignment="Center"
                   PlaceholderText="输入命令或搜索会话…" />
          <Border Grid.Column="2"
                  Background="{DynamicResource PulseBgSurface}"
                  BorderBrush="{DynamicResource PulseBorderSecondary}"
                  BorderThickness="1"
                  CornerRadius="3"
                  Padding="5,2">
            <TextBlock Text="Ctrl+K"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10" />
          </Border>
        </Grid>
      </Border>

      <!-- Footer -->
      <Border DockPanel.Dock="Bottom"
              Height="32"
              Padding="16,0"
              Background="{DynamicResource PulseBgInput}"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border Background="{DynamicResource PulseBgSurface}" CornerRadius="3" Padding="4,1"
                      BorderBrush="{DynamicResource PulseBorderSecondary}" BorderThickness="1">
                <TextBlock Text="↑↓" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" />
              </Border>
              <TextBlock Text="导航" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border Background="{DynamicResource PulseBgSurface}" CornerRadius="3" Padding="4,1"
                      BorderBrush="{DynamicResource PulseBorderSecondary}" BorderThickness="1">
                <TextBlock Text="↵" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" />
              </Border>
              <TextBlock Text="确认" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border Background="{DynamicResource PulseBgSurface}" CornerRadius="3" Padding="4,1"
                      BorderBrush="{DynamicResource PulseBorderSecondary}" BorderThickness="1">
                <TextBlock Text="Esc" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" />
              </Border>
              <TextBlock Text="关闭" FontSize="10" Foreground="{DynamicResource PulseTextMuted}" VerticalAlignment="Center" />
            </StackPanel>
          </StackPanel>
          <TextBlock Grid.Column="1"
                     Text="{Binding ResultCount, StringFormat='{}{0} 个结果'}"
                     FontSize="10"
                     Foreground="{DynamicResource PulseTextMuted}" />
        </Grid>
      </Border>

      <!-- Results -->
      <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
        <ItemsControl ItemsSource="{Binding Groups}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:CommandPaletteGroup">
              <StackPanel>
                <TextBlock Classes="cat" Text="{Binding Category}" />
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CommandPaletteItem">
                      <Border Classes="pal-item"
                              Classes.selected="{Binding IsSelected}"
                              Height="38"
                              Margin="6,0"
                              Padding="10,0"
                              Tapped="OnItemTapped">
                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7"
                                     IsVisible="{Binding IsSession}"
                                     Fill="{DynamicResource PulseStatusConnected}" />
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource PulseTextPrimary}"
                                       FontFamily="{DynamicResource PulseTerminalFont}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <Border IsVisible="{Binding Tag, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="{DynamicResource PulseAccentDim}"
                                    CornerRadius="2" Padding="6,1" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Tag}"
                                         Foreground="{DynamicResource PulseAccent}"
                                         FontFamily="{DynamicResource PulseTerminalFont}"
                                         FontSize="9" />
                            </Border>
                          </StackPanel>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Hint}"
                                     Foreground="{DynamicResource PulseTextMuted}"
                                     FontFamily="{DynamicResource PulseTerminalFont}"
                                     FontSize="10"
                                     VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </DockPanel>
  </Border>
</UserControl>
