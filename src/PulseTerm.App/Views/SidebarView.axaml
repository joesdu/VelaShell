<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.Presentation.ViewModels"
             xmlns:views="using:PulseTerm.App.Views"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="876"
             x:Class="PulseTerm.App.Views.SidebarView"
             x:DataType="vm:SidebarViewModel">

  <Grid Background="{DynamicResource PulseBgSidebar}">
    <Grid.RowDefinitions>
      <RowDefinition Height="36" />
      <RowDefinition Height="*" MinHeight="120" />
      <RowDefinition Height="5" />
      <RowDefinition Height="320" MinHeight="140" />
      <RowDefinition Height="40" />
    </Grid.RowDefinitions>

    <!-- Row 1: Toolbar (36px) -->
    <Border Grid.Row="0"
            BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">

        <!-- "会话" label -->
        <TextBlock Grid.Column="0"
                   Text="资源管理器"
                   Foreground="{DynamicResource PulseTextSecondary}"
                   FontFamily="{DynamicResource PulseTerminalFont}"
                   FontSize="11"
                   FontWeight="Medium"
                   LetterSpacing="1"
                   VerticalAlignment="Center" />

        <!-- Toolbar action buttons -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="4"
                    VerticalAlignment="Center">


          <!-- Add button. PathIcon fill-renders its geometry, so lucide's stroke-only
               paths (plain lines) have zero fill area and were invisible — these two
               must be LucideIcon (stroke renderer). -->
          <Button Background="Transparent"
                  Padding="0"
                  Width="24" Height="24"
                  CornerRadius="3"
                  Cursor="Hand"
                  Click="OpenConnectionProfile_Click"
                  ToolTip.Tip="{x:Static res:Strings.Sessions}">
            <pc:LucideIcon Width="13" Height="13"
                           Data="{StaticResource Icon.plus}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>

          <!-- More button -->
          <Button Background="Transparent"
                  Padding="0"
                  Width="24" Height="24"
                  CornerRadius="3"
                  Cursor="Hand">
            <pc:LucideIcon Width="13" Height="13"
                           Data="{StaticResource Icon.ellipsis}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 2: Session Tree (fills remaining space) -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <views:SessionTreeView DataContext="{Binding SessionTree}"
                             Padding="0,8,0,8" />
    </ScrollViewer>

    <!-- Splitter between session tree and quick connect: 5px transparent grab area drawn
         as a 1px line so the two sections' heights are drag-adjustable. -->
    <Border Grid.Row="2" Height="1" VerticalAlignment="Center"
            Background="{DynamicResource PulseBorderPrimary}" />
    <GridSplitter Grid.Row="2" Background="Transparent" ResizeDirection="Rows"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

    <!-- Row 3: Recent Connections (header + recent list, default 320px, drag-resizable) -->
    <Border Grid.Row="3">
      <Grid RowDefinitions="36,*">

        <!-- Recent Connections header -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PulseBorderPrimary}"
                Padding="12,0">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="最近连接"
                       Foreground="{DynamicResource PulseTextSecondary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="11"
                       FontWeight="Medium"
                       LetterSpacing="1"
                       VerticalAlignment="Center" />
            <!-- History button (lucide history, per design slHistory) -->
            <Button Grid.Column="1"
                    Background="Transparent"
                    Padding="0"
                    Width="24" Height="24"
                    CornerRadius="3"
                    Cursor="Hand"
                    Command="{Binding RecentConnections.RefreshCommand}"
                    ToolTip.Tip="刷新最近连接"
                    VerticalAlignment="Center">
              <PathIcon Width="13" Height="13"
                        Data="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6a7 7 0 1 1 7 7 6.95 6.95 0 0 1-4.9-2.03l-1.42 1.42A8.95 8.95 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"
                        Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
          </Grid>
        </Border>

        <!-- Recent connections list: 名称-分组 + 相对时间 (per design rc1/rc2/rc3) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding RecentConnections.Connections}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RecentConnectionItemViewModel">
                <Border Height="32"
                        Padding="12,0"
                        Cursor="Hand"
                        Background="Transparent"
                        ToolTip.Tip="{Binding Tooltip}"
                        DoubleTapped="RecentConnection_DoubleTapped">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
                    </Style>
                  </Border.Styles>
                  <Grid ColumnDefinitions="Auto,*">
                    <!-- Timer icon (per design rc*Icon) -->
                    <PathIcon Grid.Column="0"
                              Width="12" Height="12"
                              Data="M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42A8.962 8.962 0 0 0 12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"
                              Foreground="{DynamicResource PulseTextTertiary}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                    <!-- 名称-分组 + 相对时间 -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="1">
                      <TextBlock Text="{Binding DisplayName}"
                                 Foreground="{DynamicResource PulseTextSecondary}"
                                 FontFamily="{DynamicResource PulseTerminalFont}"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding RelativeTime}"
                                 Foreground="{DynamicResource PulseTextMuted}"
                                 FontFamily="{DynamicResource PulseTerminalFont}"
                                 FontSize="9" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Row 4: Sidebar Footer (40px) -->
    <Border Grid.Row="4"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PulseBorderPrimary}"
            Padding="12,0">
      <Grid ColumnDefinitions="*,Auto">

        <!-- User info: avatar + name -->
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <!-- Avatar circle -->
          <Border Width="22" Height="22"
                  CornerRadius="11"
                  Background="{DynamicResource PulseAccentDim}">
            <PathIcon Width="12" Height="12"
                      Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"
                      Foreground="{DynamicResource PulseAccent}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="root"
                     Foreground="{DynamicResource PulseTextSecondary}"
                     FontFamily="{DynamicResource PulseTerminalFont}"
                     FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Action buttons: notifications + settings -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center">
          <Button Width="24" Height="24"
                  Background="Transparent"
                  Padding="0"
                  CornerRadius="3"
                  Command="{Binding NotificationsCommand}"
                  ToolTip.Tip="{x:Static res:Strings.Notifications}"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
          <Button Width="24" Height="24"
                  Background="Transparent"
                  Padding="0"
                  CornerRadius="3"
                  Click="OpenSettings_Click"
                  ToolTip.Tip="{x:Static res:Strings.Settings}"
                  Cursor="Hand">
            <PathIcon Width="13" Height="13"
                      Data="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                      Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</UserControl>
