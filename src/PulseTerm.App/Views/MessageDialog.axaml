<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pc="using:PulseTerm.Controls.Controls"
        mc:Ignorable="d" d:DesignWidth="444" d:DesignHeight="220"
        x:Class="PulseTerm.App.Views.MessageDialog"
        Width="444"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <!-- 通用消息/确认/输入弹窗。外观遵循设计的标准弹窗规格(如 oNZIM 密码验证弹窗):
       420px bg-surface 卡片、圆角 8、1px border-secondary 外描边、阴影 0 8 32 #80000000;
       48px 标题栏(可拖动) + 内容区 + 52px 按钮栏,分隔线均为 border-primary。 -->

  <Window.Styles>
    <!-- 标题栏语义图标着色:代码侧只挂类名,画刷交给 DynamicResource(带主题变体解析;
         代码里的 FindResource 不带变体查不到 ThemeDictionaries 的画刷)。 -->
    <Style Selector="pc|LucideIcon#KindIcon.info">
      <Setter Property="Foreground" Value="{DynamicResource PulseInfo}" />
    </Style>
    <Style Selector="pc|LucideIcon#KindIcon.success">
      <Setter Property="Foreground" Value="{DynamicResource PulseAccent}" />
    </Style>
    <Style Selector="pc|LucideIcon#KindIcon.warning">
      <Setter Property="Foreground" Value="{DynamicResource PulseWarning}" />
    </Style>
    <Style Selector="pc|LucideIcon#KindIcon.error">
      <Setter Property="Foreground" Value="{DynamicResource PulseError}" />
    </Style>
    <Style Selector="pc|LucideIcon#KindIcon.question">
      <Setter Property="Foreground" Value="{DynamicResource PulseAccent}" />
    </Style>

    <!-- 自定义内容区(属性表/权限矩阵等)默认文字样式:调用方只挂类名,不在代码里取画刷。 -->
    <Style Selector="ContentControl#BodyHost TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="ContentControl#BodyHost TextBlock.dim">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
    </Style>
    <Style Selector="ContentControl#BodyHost TextBlock.mono">
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
    </Style>
    <Style Selector="ContentControl#BodyHost TextBlock.mono-accent">
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseAccentText}" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="ContentControl#BodyHost pc|LucideIcon.folder">
      <Setter Property="Foreground" Value="{DynamicResource PulseFileFolderIcon}" />
    </Style>
    <Style Selector="ContentControl#BodyHost pc|LucideIcon.file">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextTertiary}" />
    </Style>
    <Style Selector="ContentControl#BodyHost TextBox">
      <Setter Property="Background" Value="{DynamicResource PulseBgInput}" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderPrimary}" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
    </Style>

    <Style Selector="Button.dlg-outline">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.dlg-primary">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.dlg-danger">
      <Setter Property="Background" Value="{DynamicResource PulseError}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
  </Window.Styles>

  <Border CornerRadius="8"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12"
          ClipToBounds="True">
    <Grid RowDefinitions="48,Auto,52">

      <!-- 标题栏 -->
      <Border Grid.Row="0" Padding="20,0"
              Background="Transparent"
              PointerPressed="Header_PointerPressed"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <pc:LucideIcon Name="KindIcon" Width="15" Height="15"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1" Name="TitleText"
                     Foreground="{DynamicResource PulseTextPrimary}"
                     FontSize="13" FontWeight="SemiBold"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
          <Button Grid.Column="2" Width="24" Height="24"
                  Background="Transparent" Padding="0" CornerRadius="3"
                  Cursor="Hand" Click="Close_Click"
                  VerticalAlignment="Center">
            <pc:LucideIcon Width="13" Height="13"
                           Data="{DynamicResource Icon.x}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- 内容区 -->
      <StackPanel Grid.Row="1" Margin="20,16" Spacing="12">
        <TextBlock Name="MessageText"
                   Foreground="{DynamicResource PulseTextSecondary}"
                   FontSize="12" LineHeight="19"
                   TextWrapping="Wrap" />
        <TextBox Name="InputBox" IsVisible="False"
                 Background="{DynamicResource PulseBgInput}"
                 Foreground="{DynamicResource PulseTextPrimary}"
                 BorderBrush="{DynamicResource PulseBorderPrimary}"
                 CornerRadius="4" MinHeight="30" FontSize="11"
                 FontFamily="{DynamicResource PulseTerminalFont}" />
        <ContentControl Name="BodyHost" IsVisible="False" />
      </StackPanel>

      <!-- 按钮栏 -->
      <Border Grid.Row="2" Padding="20,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button Name="CancelButton" Classes="dlg-outline" IsCancel="True" Click="Cancel_Click" />
          <Button Name="ConfirmButton" Classes="dlg-primary" IsDefault="True" Click="Confirm_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
