<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pvm="using:PulseTerm.Presentation.ViewModels"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="24"
             x:Class="PulseTerm.App.Views.StatusBarView"
             x:DataType="pvm:StatusBarViewModel">

  <!-- Design frame gzmsb: 24px, bg-sidebar, 1px top border, padding [0,12], space-between.
       Left (1y2au, gap 14): wifi + "SSH • host:port" + | + latency(accent) + | + uptime.
       Right (4Cio1, gap 12): term type | size | cpu | mem | net | encoding. -->

  <UserControl.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.divider">
      <Setter Property="Width" Value="1" />
      <Setter Property="Height" Value="12" />
      <Setter Property="Background" Value="{DynamicResource PulseBorderSecondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <Border Height="24"
          Background="{DynamicResource PulseBgSidebar}"
          BorderBrush="{DynamicResource PulseBorderPrimary}"
          BorderThickness="0,1,0,0"
          Padding="12,0">
    <Grid ColumnDefinitions="Auto,*,Auto">

      <!-- Left group (gap 14) -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
        <pc:LucideIcon Width="12" Height="12"
                       Data="{StaticResource Icon.wifi}"
                       Foreground="{DynamicResource PulseStatusConnected}"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsConnected}" />
        <TextBlock Text="{Binding ConnectionInfo}"
                   Foreground="{DynamicResource PulseTextSecondary}"
                   IsVisible="{Binding ConnectionInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Border Classes="divider"
                IsVisible="{Binding Latency, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Foreground="{DynamicResource PulseAccent}"
                   Text="{Binding Latency, StringFormat='Latency: {0}'}"
                   IsVisible="{Binding Latency, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Border Classes="divider"
                IsVisible="{Binding Uptime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Foreground="{DynamicResource PulseTextTertiary}"
                   Text="{Binding Uptime, StringFormat='↑ {0}'}"
                   IsVisible="{Binding Uptime, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Foreground="{DynamicResource PulseTextSecondary}"
                   Text="{Binding StatusText}"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>

      <!-- Right group (gap 12) -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
        <TextBlock Text="{Binding TerminalType}"
                   Foreground="{DynamicResource PulseTextMuted}" />
        <Border Classes="divider" />
        <TextBlock Text="{Binding WindowSize}"
                   Foreground="{DynamicResource PulseTextMuted}" />
        <Border Classes="divider" />
        <StackPanel Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding CpuUsage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <pc:LucideIcon Width="11" Height="11" Data="{StaticResource Icon.cpu}"
                         Foreground="{DynamicResource PulseTextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding CpuUsage}" Foreground="{DynamicResource PulseTextSecondary}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding MemUsage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <pc:LucideIcon Width="11" Height="11" Data="{StaticResource Icon.memory-stick}"
                         Foreground="{DynamicResource PulseTextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding MemUsage}" Foreground="{DynamicResource PulseTextSecondary}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding NetUsage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <pc:LucideIcon Width="11" Height="11" Data="{StaticResource Icon.arrow-up-down}"
                         Foreground="{DynamicResource PulseTextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding NetUsage}" Foreground="{DynamicResource PulseTextSecondary}" />
        </StackPanel>
        <Border Classes="divider" />
        <TextBlock Text="{Binding Encoding}"
                   Foreground="{DynamicResource PulseTextMuted}" />
      </StackPanel>

    </Grid>
  </Border>
</UserControl>
