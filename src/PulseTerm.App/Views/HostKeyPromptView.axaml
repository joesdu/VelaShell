<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PulseTerm.App.ViewModels"
        xmlns:pc="using:PulseTerm.Controls.Controls"
        xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
        mc:Ignorable="d" d:DesignWidth="484" d:DesignHeight="400"
        x:Class="PulseTerm.App.Views.HostKeyPromptView"
        x:DataType="vm:HostKeyPromptViewModel"
        Title="{x:Static res:Strings.HostKeyVerification}"
        Width="484"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

  <!-- 主机密钥验证(TOFU)。外壳遵循标准弹窗规格:bg-surface 卡片、圆角 8、
       1px border-secondary、阴影 0 8 32 #80000000、48px 可拖动标题栏 + 52px 按钮栏。 -->

  <Window.Styles>
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="{DynamicResource PulseTerminalFont}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource PulseAccentText}" />
    </Style>
    <Style Selector="TextBlock.info-label">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextSecondary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,12,0" />
    </Style>
    <Style Selector="TextBlock.info-value">
      <Setter Property="Foreground" Value="{DynamicResource PulseTextPrimary}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.trust">
      <Setter Property="Background" Value="{DynamicResource PulseAccent}" />
      <Setter Property="Foreground" Value="#0A0E14" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.reject">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PulseError}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PulseBorderSecondary}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </Window.Styles>

  <Border CornerRadius="8"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          BoxShadow="0 8 32 0 #80000000"
          Margin="12"
          ClipToBounds="True">
    <Grid RowDefinitions="48,Auto,52">

      <!-- 标题栏(可拖动) -->
      <Border Grid.Row="0" Padding="20,0"
              Background="Transparent"
              PointerPressed="Header_PointerPressed"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <pc:LucideIcon Width="15" Height="15"
                         Data="{DynamicResource Icon.shield}"
                         Foreground="{DynamicResource PulseWarning}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBlock Grid.Column="1"
                     Text="{x:Static res:Strings.HostKeyVerification}"
                     Foreground="{DynamicResource PulseTextPrimary}"
                     FontSize="13" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2" Width="24" Height="24"
                  Background="Transparent" Padding="0" CornerRadius="3"
                  Cursor="Hand" Command="{Binding RejectCommand}"
                  VerticalAlignment="Center">
            <pc:LucideIcon Width="13" Height="13"
                           Data="{DynamicResource Icon.x}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- 内容区 -->
      <StackPanel Grid.Row="1" Margin="20,16" Spacing="14">

        <!-- Warning banner -->
        <Border Background="{DynamicResource PulseBgActive}"
                CornerRadius="6"
                Padding="16,12">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <pc:LucideIcon Width="16" Height="16"
                           VerticalAlignment="Top"
                           Data="{DynamicResource Icon.triangle-alert}"
                           Foreground="{DynamicResource PulseWarning}" />
            <TextBlock Text="{Binding WarningText}"
                       Foreground="{DynamicResource PulseWarning}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="360"
                       VerticalAlignment="Center"
                       IsVisible="{Binding !IsChanged}" />
            <TextBlock Text="{Binding WarningText}"
                       Foreground="{DynamicResource PulseError}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       MaxWidth="360"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsChanged}" />
          </StackPanel>
        </Border>

        <!-- Host info (bg-input 与卡片底色区分,同设计 authInfo 条) -->
        <Border Background="{DynamicResource PulseBgInput}"
                BorderBrush="{DynamicResource PulseBorderPrimary}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16,12">
          <StackPanel Spacing="8">

            <Grid ColumnDefinitions="100,*">
              <TextBlock Grid.Column="0" Classes="info-label" Text="{x:Static res:Strings.Host}" />
              <TextBlock Grid.Column="1" Classes="info-value">
                <Run Text="{Binding Host}" /><Run Text=":" /><Run Text="{Binding Port}" />
              </TextBlock>
            </Grid>

            <Grid ColumnDefinitions="100,*">
              <TextBlock Grid.Column="0" Classes="info-label" Text="{x:Static res:Strings.KeyType}" />
              <TextBlock Grid.Column="1" Classes="info-value" Text="{Binding KeyType}" />
            </Grid>

            <Grid ColumnDefinitions="100,*">
              <TextBlock Grid.Column="0" Classes="info-label" Text="{x:Static res:Strings.Fingerprint}" />
              <TextBlock Grid.Column="1" Classes="mono"
                         Text="{Binding Fingerprint}"
                         TextWrapping="Wrap" />
            </Grid>

          </StackPanel>
        </Border>

      </StackPanel>

      <!-- 按钮栏 -->
      <Border Grid.Row="2" Padding="20,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,1,0,0">
        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button Classes="reject"
                  Content="{x:Static res:Strings.Reject}"
                  Command="{Binding RejectCommand}" />
          <Button Classes="trust"
                  Content="{x:Static res:Strings.Trust}"
                  Command="{Binding TrustCommand}" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>
