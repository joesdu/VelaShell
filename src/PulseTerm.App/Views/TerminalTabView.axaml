<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:views="using:PulseTerm.App.Views"
             xmlns:controls="using:PulseTerm.App.Controls"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="PulseTerm.App.Views.TerminalTabView"
             x:DataType="vm:TerminalTabViewModel">

  <Grid RowDefinitions="*,Auto">

    <!-- Row 1: in-terminal search bar (spec §5.3, Ctrl+F) — docked at the bottom of this
         tab (per-tab scope; it only searches this tab's buffer). -->
    <Border Grid.Row="1"
              x:Name="SearchBar"
              IsVisible="False"
              Background="{DynamicResource PulseBgSurface}"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,1,0,0"
              Padding="14,4">
        <Grid ColumnDefinitions="Auto,8,240,8,Auto,4,Auto,4,Auto,8,Auto">
          <pc:LucideIcon Grid.Column="0" Width="12" Height="12"
                         Data="{StaticResource Icon.search}"
                         Foreground="{DynamicResource PulseTextTertiary}"
                         VerticalAlignment="Center" />
          <TextBox x:Name="SearchBox" Grid.Column="2"
                   MinHeight="24" Padding="8,2" CornerRadius="3"
                   FontFamily="{DynamicResource PulseTerminalFont}" FontSize="11"
                   Background="{DynamicResource PulseBgInput}"
                   Foreground="{DynamicResource PulseTextPrimary}"
                   BorderBrush="{DynamicResource PulseBorderPrimary}"
                   PlaceholderText="在终端中查找" />
          <TextBlock x:Name="SearchCount" Grid.Column="4"
                     Foreground="{DynamicResource PulseTextMuted}"
                     FontFamily="{DynamicResource PulseTerminalFont}" FontSize="10"
                     VerticalAlignment="Center" />
          <Button x:Name="SearchPrev" Grid.Column="6"
                  Width="22" Height="22" Padding="0" Background="Transparent" CornerRadius="3"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="上一个 (Shift+Enter)">
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.chevron-left}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
          <Button x:Name="SearchNext" Grid.Column="8"
                  Width="22" Height="22" Padding="0" Background="Transparent" CornerRadius="3"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="下一个 (Enter)">
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.chevron-right}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
          <Button x:Name="SearchClose" Grid.Column="10"
                  Width="22" Height="22" Padding="0" Background="Transparent" CornerRadius="3"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  ToolTip.Tip="关闭 (Esc)">
            <pc:LucideIcon Width="12" Height="12" Data="{StaticResource Icon.x}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

    <!-- Row 0: Terminal area with scrollbar -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">

      <!-- Terminal emulator control -->
      <Border Grid.Column="0"
              Background="{DynamicResource PulseBgTerminal}"
              ClipToBounds="True">
        <controls:ReparentingHost Target="{Binding TerminalEmulator.Control}" />
      </Border>

      <!-- Scrollbar for scrollback navigation (driven from code-behind against the
           shared terminal control, since the control is reparented across split panes). -->
      <ScrollBar Grid.Column="1"
                 x:Name="ScrollBarView"
                 Orientation="Vertical"
                 Minimum="0"
                 AllowAutoHide="False"
                 Background="{DynamicResource PulseBgSurface}"
                 Width="12"
                 Opacity="0.6" />

    </Grid>
  </Grid>
</UserControl>
