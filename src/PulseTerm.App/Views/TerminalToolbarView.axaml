<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             xmlns:loc="using:PulseTerm.App.Localization"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="28"
             x:Class="PulseTerm.App.Views.TerminalToolbarView"
             x:DataType="vm:TerminalTabViewModel">

  <!-- Slim per-tab action row (用户反馈 #5): quick disconnect / reconnect for the current
       session on the left, latency readout on the right. The old host/uptime text and the
       search/copy/split/tunnel/broadcast buttons were removed pending a better concept. -->
  <Border Background="Transparent"
          BorderThickness="0,0,0,1"
          BorderBrush="{DynamicResource PulseBorderPrimary}"
          Height="28">
    <Grid ColumnDefinitions="Auto,*,Auto">

      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="14,0,0,0"
                  Spacing="8">

        <!-- 断开连接: shown while the session is live -->
        <Button Height="20" Padding="8,0" CornerRadius="3" Cursor="Hand"
                Background="Transparent"
                BorderBrush="{DynamicResource PulseBorderSecondary}"
                BorderThickness="1"
                IsVisible="{Binding IsConnected}"
                Command="{Binding DisconnectCommand}">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <pc:LucideIcon Width="11" Height="11"
                           Data="{StaticResource Icon.unplug}"
                           Foreground="{DynamicResource PulseStatusDisconnected}" />
            <TextBlock Text="{loc:Localize Disconnect}"
                       Foreground="{DynamicResource PulseTextSecondary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- 重新连接: shown while disconnected -->
        <Button Height="20" Padding="8,0" CornerRadius="3" Cursor="Hand"
                Background="{DynamicResource PulseAccentDim}"
                IsVisible="{Binding !IsConnected}"
                Command="{Binding ReconnectCommand}">
          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <pc:LucideIcon Width="11" Height="11"
                           Data="{StaticResource Icon.refresh-cw}"
                           Foreground="{DynamicResource PulseAccent}" />
            <TextBlock Text="{loc:Localize Reconnect}"
                       Foreground="{DynamicResource PulseAccent}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10" FontWeight="Medium"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

      </StackPanel>

      <!-- Latency in status-connected color -->
      <TextBlock Grid.Column="2"
                 Margin="0,0,14,0"
                 Foreground="{DynamicResource PulseStatusConnected}"
                 FontFamily="{DynamicResource PulseTerminalFont}"
                 FontSize="10"
                 VerticalAlignment="Center"
                 IsVisible="{Binding Latency, Converter={x:Static ObjectConverters.IsNotNull}}">
        <TextBlock.Text>
          <MultiBinding StringFormat="latency: {0:fff}ms">
            <Binding Path="Latency" />
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
    </Grid>
  </Border>
</UserControl>
