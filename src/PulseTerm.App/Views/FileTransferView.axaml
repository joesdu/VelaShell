<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="160"
             x:Class="PulseTerm.App.Views.FileTransferView"
             x:DataType="vm:FileTransferViewModel">

  <!-- Floating transfer toast per design frame 9Ralg: 280px, bg-surface, corner 6,
       1px border-secondary, shadow blur16 y+4. Exists only while transfers exist;
       auto-fades ~3s after all complete; x collapses without cancelling (spec §9). -->

  <Border Width="280"
          Background="{DynamicResource PulseBgSurface}"
          BorderBrush="{DynamicResource PulseBorderSecondary}"
          BorderThickness="1"
          CornerRadius="6"
          BoxShadow="0 4 16 0 #60000000"
          IsVisible="{Binding IsPanelVisible}">
    <StackPanel>

      <!-- Header (32px, drag handle): arrow-up-down accent + 传输 + count badge | x -->
      <Border Height="32"
              Padding="12,0"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <pc:LucideIcon Width="12" Height="12"
                           Data="{StaticResource Icon.arrow-up-down}"
                           Foreground="{DynamicResource PulseAccent}" />
            <TextBlock Text="传输"
                       Foreground="{DynamicResource PulseTextPrimary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="11" FontWeight="Medium"
                       VerticalAlignment="Center" />
            <Border Background="{DynamicResource PulseAccent}"
                    CornerRadius="8" Padding="6,1"
                    VerticalAlignment="Center"
                    IsVisible="{Binding ActiveCount}">
              <TextBlock Text="{Binding ActiveCount}"
                         Foreground="{DynamicResource PulseAccentText}"
                         FontFamily="{DynamicResource PulseTerminalFont}"
                         FontSize="9" FontWeight="Medium" />
            </Border>
          </StackPanel>
          <Button Grid.Column="2"
                  Background="Transparent" Padding="2" Cursor="Hand"
                  Command="{Binding HidePanelCommand}"
                  ToolTip.Tip="收起（任务继续后台执行）">
            <pc:LucideIcon Width="12" Height="12"
                           Data="{StaticResource Icon.x}"
                           Foreground="{DynamicResource PulseTextTertiary}" />
          </Button>
        </Grid>
      </Border>

      <!-- Transfer rows: keep panel height bounded (~5 rows) and scroll overflow. -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    MaxHeight="280">
        <ItemsControl ItemsSource="{Binding Transfers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:TransferItemViewModel">
              <Border Padding="12,8"
                      BorderBrush="{DynamicResource PulseBorderPrimary}"
                      BorderThickness="0,0,0,1">
                <StackPanel Spacing="4">

                  <!-- Name / percentage -->
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding FileName}"
                               Foreground="{DynamicResource PulseTextPrimary}"
                               FontFamily="{DynamicResource PulseTerminalFont}"
                               FontSize="10" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressText}"
                               FontFamily="{DynamicResource PulseTerminalFont}"
                               FontSize="10" FontWeight="Medium"
                               Classes.done="{Binding IsCompleted}"
                               Classes.failed="{Binding IsFailed}">
                      <TextBlock.Styles>
                        <Style Selector="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource PulseAccent}" />
                        </Style>
                        <Style Selector="TextBlock.done">
                          <Setter Property="Foreground" Value="{DynamicResource PulseStatusConnected}" />
                        </Style>
                        <Style Selector="TextBlock.failed">
                          <Setter Property="Foreground" Value="{DynamicResource PulseError}" />
                        </Style>
                      </TextBlock.Styles>
                    </TextBlock>
                  </Grid>

                  <!-- Progress bar: 3px track border-primary + accent fill -->
                  <ProgressBar Minimum="0" Maximum="100"
                               Value="{Binding Progress}"
                               Height="3" MinHeight="3"
                               CornerRadius="2"
                               Background="{DynamicResource PulseBorderPrimary}"
                               Foreground="{DynamicResource PulseAccent}" />

                  <!-- Detail line -->
                  <TextBlock Text="{Binding InfoLine}"
                             Foreground="{DynamicResource PulseTextMuted}"
                             FontFamily="{DynamicResource PulseTerminalFont}"
                             FontSize="9" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </StackPanel>
  </Border>
</UserControl>
