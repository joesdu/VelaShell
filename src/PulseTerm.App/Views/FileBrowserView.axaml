<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             xmlns:res="clr-namespace:PulseTerm.Core.Resources;assembly=PulseTerm.Core"
             xmlns:pc="using:PulseTerm.Controls.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="220"
             x:Class="PulseTerm.App.Views.FileBrowserView"
             x:DataType="vm:FileBrowserViewModel">

  <UserControl.Styles>
    <Style Selector="Button.toolbar-btn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
    </Style>
  </UserControl.Styles>

  <Border BorderThickness="0,1,0,0"
          BorderBrush="{DynamicResource PulseBorderPrimary}"
          Background="{DynamicResource PulseBgPage}"
          IsVisible="{Binding IsVisible}"
          MinHeight="120"
          Height="220">

    <Panel>
      <DockPanel>

      <!-- Header per design frame cKZr7: 36px, padding [0,14], bottom border;
           left = folder-open 14 accent + path (JB Mono 11 medium); right = accent-dim
           upload pill + 24×24 refresh. -->
      <Border DockPanel.Dock="Top"
              Height="36"
              BorderBrush="{DynamicResource PulseBorderPrimary}"
              BorderThickness="0,0,0,1"
              Padding="14,0">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <pc:LucideIcon Width="14" Height="14"
                           Data="{StaticResource Icon.folder-open}"
                           Foreground="{DynamicResource PulseAccent}"
                           VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentPath}"
                       Foreground="{DynamicResource PulseTextPrimary}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="11" FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Button Height="24" Padding="8,0" CornerRadius="3" Cursor="Hand"
                    Background="{DynamicResource PulseAccentDim}"
                    Command="{Binding UploadCommand}"
                    ToolTip.Tip="{x:Static res:Strings.Upload}">
              <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <pc:LucideIcon Width="12" Height="12"
                               Data="{StaticResource Icon.upload}"
                               Foreground="{DynamicResource PulseAccent}" />
                <TextBlock Text="{x:Static res:Strings.Upload}"
                           Foreground="{DynamicResource PulseAccent}"
                           FontFamily="{DynamicResource PulseTerminalFont}"
                           FontSize="10" FontWeight="Medium"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding RefreshCommand}"
                    ToolTip.Tip="{x:Static res:Strings.Refresh}">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.refresh-cw}"
                             Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding GoUpCommand}"
                    ToolTip.Tip="上级目录">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.corner-left-up}"
                             Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding CreateFolderCommand}"
                    ToolTip.Tip="新建文件夹">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.folder}"
                             Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding DownloadCommand}"
                    ToolTip.Tip="{x:Static res:Strings.Download}">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.arrow-up-down}"
                             Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
            <Button Classes="toolbar-btn" Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding DeleteCommand}"
                    ToolTip.Tip="{x:Static res:Strings.Delete}">
              <pc:LucideIcon Width="13" Height="13"
                             Data="{StaticResource Icon.x}"
                             Foreground="{DynamicResource PulseTextTertiary}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Top"
              IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
              Background="{DynamicResource PulseBgActive}"
              Padding="8,4">
        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource PulseAccent}"
                   FontSize="11" />
      </Border>

      <Grid RowDefinitions="26,*">

        <Border Grid.Row="0"
                Background="{DynamicResource PulseBgSurface}"
                BorderBrush="{DynamicResource PulseBorderPrimary}"
                BorderThickness="0,0,0,1"
                Padding="14,0">
          <Grid ColumnDefinitions="*,100,110,140">
            <TextBlock Grid.Column="0"
                       Text="{x:Static res:Strings.FileName}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{x:Static res:Strings.Size}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="2"
                       Text="{x:Static res:Strings.Permissions}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="3"
                       Text="{x:Static res:Strings.Modified}"
                       Foreground="{DynamicResource PulseTextMuted}"
                       FontFamily="{DynamicResource PulseTerminalFont}"
                       FontSize="10"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Files}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RemoteFileInfoViewModel">
                <Border Background="Transparent"
                        BorderBrush="{DynamicResource PulseBorderSecondary}"
                        BorderThickness="0,0,0,1"
                        Height="32"
                        Padding="12,0">
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="Background" Value="{DynamicResource PulseBgHover}" />
                    </Style>
                  </Border.Styles>
                  <Grid ColumnDefinitions="*,100,110,140">
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                      <PathIcon Width="14"
                                Height="14"
                                Foreground="{DynamicResource PulseTextTertiary}"
                                IsVisible="{Binding IsDirectory}"
                                Data="M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
                      <PathIcon Width="14"
                                Height="14"
                                Foreground="{DynamicResource PulseTextTertiary}"
                                IsVisible="{Binding !IsDirectory}"
                                Data="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z" />
                      <TextBlock Text="{Binding Name}"
                                 Foreground="{DynamicResource PulseTextPrimary}"
                                 FontSize="11"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding FormattedSize}"
                               Foreground="{DynamicResource PulseTextSecondary}"
                               FontFamily="{DynamicResource PulseTerminalFont}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Permissions}"
                               Foreground="{DynamicResource PulseTextSecondary}"
                               FontFamily="{DynamicResource PulseTerminalFont}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding FormattedModifiedTime}"
                               Foreground="{DynamicResource PulseTextSecondary}"
                               FontFamily="{DynamicResource PulseTerminalFont}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

      </Grid>

    </DockPanel>

      <!-- Loading overlay -->
      <Border IsVisible="{Binding IsLoading}"
              Background="{DynamicResource PulseBgSurface}"
              Opacity="0.8"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
        <TextBlock Text="Loading..."
                   Foreground="{DynamicResource PulseTextSecondary}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="13" />
      </Border>
    </Panel>
  </Border>
</UserControl>
