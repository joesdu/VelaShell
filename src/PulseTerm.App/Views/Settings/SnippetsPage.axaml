<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             x:Class="PulseTerm.App.Views.Settings.SnippetsPage"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="14">
    <StackPanel Spacing="2">
      <TextBlock Classes="page-title" Text="脚本/片段库管理" />
      <TextBlock Classes="page-subtitle" Text="// 常用命令片段,可在快捷命令面板中执行" />
    </StackPanel>

    <TextBlock Text="您可以创建常用的命令片段,绑定到快捷键,或分配给特定的会话。"
               Foreground="{DynamicResource PulseTextSecondary}"
               FontSize="13" TextWrapping="Wrap" />

    <!-- 片段列表(数据:SonnetDB quick_commands 集合 + 内置命令) -->
    <ItemsControl ItemsSource="{Binding Snippets.AllCommands}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Spacing="8" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:QuickCommandViewModel">
          <Border CornerRadius="6" Padding="12"
                  Background="{DynamicResource PulseBgSurface}"
                  BorderBrush="{DynamicResource PulseBorderSecondary}"
                  BorderThickness="1">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="Background" Value="{DynamicResource PulseBgActive}" />
              </Style>
            </Border.Styles>
            <Grid ColumnDefinitions="*,Auto,8,Auto">
              <TextBlock Text="{Binding Name}"
                         Foreground="{DynamicResource PulseTextPrimary}"
                         FontSize="13" FontWeight="Medium"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Border Grid.Column="1"
                      Background="{DynamicResource PulseBgInput}"
                      CornerRadius="4" Padding="8,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding CommandText}"
                           Foreground="#69FF94"
                           FontFamily="{DynamicResource PulseTerminalFont}"
                           FontSize="11" />
              </Border>
              <Button Grid.Column="3" Width="24" Height="24" Padding="0"
                      Background="Transparent" CornerRadius="3" Cursor="Hand"
                      ToolTip.Tip="删除片段(内置片段不可删除)"
                      Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).Snippets.DeleteCommandCommand}"
                      CommandParameter="{Binding}"
                      VerticalAlignment="Center">
                <PathIcon Width="12" Height="12"
                          Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                          Foreground="{DynamicResource PulseTextTertiary}" />
              </Button>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Classes="sep" />

    <!-- 新建片段 -->
    <TextBlock Classes="section-title" Text="新建片段" />
    <Grid ColumnDefinitions="*,8,*,8,Auto">
      <TextBox Grid.Column="0" Text="{Binding Snippets.NewName}" Watermark="名称,如 Check Docker Status" />
      <TextBox Grid.Column="2" Text="{Binding Snippets.NewCommandText}" Watermark="命令,如 systemctl status docker" />
      <Button Grid.Column="4" Classes="dlg-primary" Content="添加"
              Command="{Binding Snippets.SaveNewCommandCommand}" />
    </Grid>
  </StackPanel>
</UserControl>
