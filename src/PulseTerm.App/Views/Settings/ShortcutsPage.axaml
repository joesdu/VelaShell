<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PulseTerm.App.ViewModels"
             x:Class="PulseTerm.App.Views.Settings.ShortcutsPage"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="14">
    <StackPanel Spacing="2">
      <TextBlock Classes="page-title" Text="快捷键" />
      <TextBlock Classes="page-subtitle" Text="// 自定义键盘快捷键绑定" />
    </StackPanel>

    <ItemsControl ItemsSource="{Binding ShortcutGroups}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Spacing="14" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ShortcutGroup">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="{Binding Title}" />
            <Border Classes="table">
              <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ShortcutItem">
                    <Border Height="36" Padding="12,0"
                            BorderBrush="{DynamicResource PulseBorderPrimary}"
                            BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{DynamicResource PulseTextSecondary}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Keys}"
                                      VerticalAlignment="Center">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                              <Border Classes="keycap">
                                <TextBlock Text="{Binding}"
                                           Foreground="{DynamicResource PulseTextSecondary}"
                                           FontFamily="{DynamicResource PulseTerminalFont}"
                                           FontSize="10" FontWeight="Medium" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </StackPanel>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <StackPanel Orientation="Horizontal" Spacing="6">
      <PathIcon Width="12" Height="12"
                Data="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                Foreground="{DynamicResource PulseTextMuted}" VerticalAlignment="Center" />
      <TextBlock Classes="row-desc" Text="自定义键位将在后续版本提供;当前展示为内置绑定" VerticalAlignment="Center" />
    </StackPanel>
  </StackPanel>
</UserControl>
