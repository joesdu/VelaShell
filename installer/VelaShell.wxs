<?xml version="1.0" encoding="UTF-8"?>
<!-- VelaShell MSI(WiX v4+ schema):
     wix build installer/VelaShell.wxs -arch x64|arm64 -pdbtype none
         -ext WixToolset.UI.wixext -culture zh-CN
         -d ProductVersion=0.1.0 -d PublishDir=<发布目录> -d IconPath=<ico> -o VelaShell.msi
     ProductVersion 必须为纯数字 x.y.z(MSI 规范不允许 -beta 后缀);
     UpgradeCode 固定不变(升级识别),ProductId 每次生成(MajorUpgrade)。
     安装向导 WixUI_InstallDir 支持自定义安装目录;静默安装同样可指定:
     msiexec /i VelaShell.msi /qn INSTALLFOLDER="D:\Tools\VelaShell" -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="VelaShell"
           Manufacturer="joesdu"
           Version="$(var.ProductVersion)"
           UpgradeCode="7b0e4a3c-9f2d-4e64-b7a1-52c3f4d8e901"
           Language="2052"
           Codepage="65001"
           Compressed="yes"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="已安装较新版本的 VelaShell,无法降级安装。" />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- 安装向导:许可 → 选择安装目录 → 安装(WixUI_InstallDir 标准对话框集) -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="VelaShell">
        <!-- 发布目录整体收纳(排除调试符号) -->
        <Files Include="$(var.PublishDir)\**">
          <Exclude Files="$(var.PublishDir)\**\*.pdb" />
        </Files>
      </Directory>
    </StandardDirectory>

    <!-- 开始菜单快捷方式 -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="8c1f5b2a-3d47-4a80-9e63-14f7a6c2d035">
        <Shortcut Id="StartMenuEntry"
                  Name="VelaShell"
                  Target="[INSTALLFOLDER]VelaShell.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU" Key="Software\VelaShell" Name="StartMenuShortcut"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Package>
</Wix>
